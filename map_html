<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WebGIS — PostgreSQL в браузере</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/@turf/turf@6/turf.min.js"></script>
<style>
@import url('https://cdn.jsdelivr.net/npm/@fontsource/inter@5.0.0/index.min.css');
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',-apple-system,sans-serif;background:#f2f3f7;color:#333;overflow:hidden;height:100vh}
:root{--blue:#2b7de9;--blue-h:#1a6ad4;--blue-light:#e8f1fc;--dark:#1d2530;--dark-h:#2a3444;--gray:#f2f3f7;--border:#d8dbe2;--gray-t:#6b7280;--white:#fff;--red:#e53935;--green:#2e7d32;--orange:#f59e0b;--shadow:0 1px 3px rgba(0,0,0,.08);--shadow-lg:0 4px 12px rgba(0,0,0,.1);--shadow-xl:0 10px 30px rgba(0,0,0,.12);--r:8px;--rl:12px}

/* === AUTH STYLES === */
.auth-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:linear-gradient(135deg,var(--dark) 0%,#2a3444 100%);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px}
.auth-overlay.hidden{display:none}
.auth-card{background:var(--white);border-radius:var(--rl);width:100%;max-width:420px;box-shadow:var(--shadow-xl);overflow:hidden;animation:slideUp .3s ease}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.auth-header{background:var(--dark);padding:24px 28px;text-align:center;border-bottom:3px solid var(--blue)}
.auth-header .logo{font-weight:700;font-size:20px;color:#fff;display:flex;align-items:center;justify-content:center;gap:10px}
.auth-header .logo i{color:var(--blue);font-size:24px}
.auth-header .logo small{font-weight:400;color:rgba(255,255,255,.5);font-size:12px;margin-left:4px}
.auth-body{padding:28px}
.auth-title{font-size:16px;font-weight:600;color:#333;margin-bottom:20px;text-align:center}
.auth-form{display:flex;flex-direction:column;gap:14px}
.auth-input-group{position:relative}
.auth-input{width:100%;background:var(--gray);border:1px solid var(--border);color:#333;padding:12px 40px 12px 14px;border-radius:var(--r);font-size:13px;outline:none;font-family:inherit;transition:all .2s}
.auth-input:focus{border-color:var(--blue);background-color:#fff;box-shadow:0 0 0 3px rgba(43,125,233,.1)}
.auth-input::placeholder{color:var(--gray-t)}
.auth-toggle{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:0 0;border:none;color:var(--gray-t);cursor:pointer;padding:4px;border-radius:4px;font-size:12px;transition:all .15s}
.auth-toggle:hover{color:var(--blue)}
.auth-options{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--gray-t)}
.auth-remember{display:flex;align-items:center;gap:6px;cursor:pointer}
.auth-remember input{accent-color:var(--blue);cursor:pointer;width:14px;height:14px}
.auth-forgot{color:var(--blue);text-decoration:none;cursor:pointer;transition:color .15s}
.auth-forgot:hover{color:var(--blue-h)}
.auth-btn{background:var(--blue);color:#fff;border:none;padding:12px;border-radius:var(--r);cursor:pointer;font-size:14px;font-weight:500;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:8px;font-family:inherit;margin-top:4px}
.auth-btn:hover{background:var(--blue-h);box-shadow:var(--shadow)}
.auth-btn:disabled{background:var(--gray-t);cursor:not-allowed}
.auth-error{background:rgba(229,57,53,.08);border:1px solid rgba(229,57,53,.2);color:var(--red);padding:10px 14px;border-radius:var(--r);font-size:12px;display:none;align-items:center;gap:8px}
.auth-error.show{display:flex}
.auth-footer{text-align:center;padding:16px 28px;border-top:1px solid var(--border);font-size:11px;color:var(--gray-t)}
.auth-demo{background:var(--blue-light);border-radius:var(--r);padding:12px;margin-top:16px;font-size:11px;color:var(--gray-t)}
.auth-demo code{background:var(--gray);padding:2px 6px;border-radius:3px;color:var(--blue);font-family:monospace}

/* === MAIN APP STYLES (unchanged) === */
.app{display:flex;flex-direction:column;height:100vh;opacity:0;transition:opacity .3s}
.app.ready{opacity:1}
.header{display:flex;align-items:center;height:56px;padding:0 20px;background:var(--dark);z-index:100;gap:16px;border-bottom:3px solid var(--blue)}
.header .logo{font-weight:700;font-size:17px;color:#fff;display:flex;align-items:center;gap:8px}
.logo i{color:var(--blue);font-size:20px}
.logo small{font-weight:400;color:rgba(255,255,255,.45);font-size:11px;margin-left:6px}
.hnav{display:flex;gap:2px;align-items:center;margin-left:24px;flex-wrap:nowrap;overflow-x:auto}
.nbtn{background:0 0;border:none;color:rgba(255,255,255,.7);padding:7px 10px;cursor:pointer;border-radius:6px;font-size:12px;display:flex;align-items:center;gap:5px;transition:all .15s;font-family:inherit;white-space:nowrap}
.nbtn:hover{background:var(--dark-h);color:#fff}
.nbtn.on{background:var(--blue);color:#fff}
.sep{width:1px;height:28px;background:rgba(255,255,255,.12);margin:0 4px;flex-shrink:0}
.hspacer{flex:1}
.coords{display:flex;gap:16px;font-size:11px;color:rgba(255,255,255,.5);font-family:monospace}
.coords b{color:rgba(255,255,255,.85);font-weight:500}
.main{display:flex;flex:1;overflow:hidden}
.sleft{width:280px;background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;transition:width .3s;overflow:hidden;box-shadow:var(--shadow);flex-shrink:0}
.sleft.collapsed{width:0;border:none;box-shadow:none}
.ssearch{padding:12px 14px;border-bottom:1px solid var(--border)}
.sinput{width:100%;background:var(--gray);border:1px solid var(--border);color:#333;padding:8px 10px 8px 32px;border-radius:var(--r);font-size:12px;outline:none;font-family:inherit;transition:all .2s}
.sinput:focus{border-color:var(--blue);background-color:#fff;box-shadow:0 0 0 3px rgba(43,125,233,.1)}
.sinput::placeholder{color:var(--gray-t)}
.shdr{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border-bottom:1px solid var(--border)}
.shdr h3{font-size:11px;text-transform:uppercase;color:var(--gray-t);letter-spacing:.5px;font-weight:600}
.ibtn{background:0 0;border:none;color:var(--gray-t);cursor:pointer;padding:4px;border-radius:4px;font-size:12px;transition:all .15s}
.ibtn:hover{background:var(--gray);color:var(--blue)}
.llist{flex:1;overflow-y:auto;padding:4px 0}
.litem{display:flex;align-items:center;padding:8px 14px;gap:8px;cursor:pointer;transition:background .12s;border-left:3px solid transparent}
.litem:hover{background:var(--blue-light)}
.litem.active{background:var(--blue-light);border-left-color:var(--blue)}
.litem input[type=checkbox]{accent-color:var(--blue);cursor:pointer;width:14px;height:14px}
.lcolor{width:16px;height:4px;border-radius:2px;flex-shrink:0}
.lname{flex:1;font-size:12px;color:#333;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.lcount{font-size:10px;color:var(--gray-t);background:var(--gray);padding:1px 5px;border-radius:8px}
.lsrc{font-size:9px;padding:1px 4px;border-radius:3px;font-weight:600}
.lsrc.pg{background:rgba(43,125,233,.1);color:var(--blue)}
.lsrc.local{background:rgba(107,114,128,.1);color:var(--gray-t)}
.lbtns{display:none;gap:3px}
.litem:hover .lbtns{display:flex}
.lbtn{background:0 0;border:none;color:var(--gray-t);cursor:pointer;padding:3px 4px;border-radius:3px;font-size:10px;transition:all .15s}
.lbtn:hover{color:var(--red);background:rgba(229,57,53,.08)}
.sright{width:400px;background:var(--white);border-left:1px solid var(--border);display:flex;flex-direction:column;transition:width .3s;overflow:hidden;box-shadow:var(--shadow);flex-shrink:0}
.sright.collapsed{width:0;border:none;box-shadow:none}
.tabs{display:flex;border-bottom:1px solid var(--border)}
.tbtn{flex:1;padding:10px 0;text-align:center;font-size:11px;cursor:pointer;border:none;background:0 0;color:var(--gray-t);border-bottom:2px solid transparent;transition:all .15s;font-family:inherit;font-weight:500}
.tbtn.on{color:var(--blue);border-bottom-color:var(--blue);background:var(--blue-light)}
.tbtn:hover:not(.on){color:#333}
.tcontent{flex:1;overflow-y:auto;display:none}
.tcontent.on{display:block}
.ppanel{padding:14px}
.pempty{text-align:center;padding:40px 20px;color:var(--gray-t)}
.pempty i{font-size:36px;display:block;margin-bottom:12px;color:var(--border)}
.pgrp{margin-bottom:16px}
.pgrpt{font-size:10px;text-transform:uppercase;color:var(--gray-t);letter-spacing:.5px;padding-bottom:6px;border-bottom:1px solid var(--border);margin-bottom:8px;font-weight:600}
.prow{display:flex;justify-content:space-between;padding:5px 0;font-size:12px;align-items:center}
.plbl{color:var(--gray-t)}
.pval{color:#333;font-weight:500;font-family:monospace;font-size:11px}
.pacts{display:flex;gap:6px;margin-top:14px;flex-wrap:wrap}
.btn{padding:7px 14px;border:none;border-radius:var(--r);cursor:pointer;font-size:12px;transition:all .15s;display:inline-flex;align-items:center;gap:5px;font-family:inherit;font-weight:500}
.btn-p{background:var(--blue);color:#fff}
.btn-p:hover{background:var(--blue-h);box-shadow:var(--shadow)}
.btn-s{background:var(--gray);color:#333;border:1px solid var(--border)}
.btn-s:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-light)}
.btn-d{background:var(--red);color:#fff}
.btn-d:hover{background:#c62828}
.btn-sm{padding:5px 8px;font-size:11px}
.btn-success{background:var(--green);color:#fff}
.btn-success:hover{background:#1b5e20}
.atoolbar{display:flex;gap:6px;padding:10px 14px;align-items:center;border-bottom:1px solid var(--border)}
.atoolbar select{flex:1;background:var(--gray);border:1px solid var(--border);color:#333;padding:6px 8px;border-radius:var(--r);font-size:11px;font-family:inherit;outline:none}
.atoolbar select:focus{border-color:var(--blue)}
.atbl{width:100%;border-collapse:collapse;font-size:11px}
.atbl th{background:var(--gray);color:var(--gray-t);padding:8px 10px;text-align:left;position:sticky;top:0;font-size:10px;text-transform:uppercase;font-weight:600;border-bottom:1px solid var(--border)}
.atbl td{padding:6px 10px;border-bottom:1px solid #f0f0f5;color:#555}
.atbl tr:hover td{background:var(--blue-light);color:#333}
.atbl tr.sel td{background:var(--blue-light);color:var(--blue);font-weight:500}
.qpanel{padding:14px}
.qpanel h4{font-size:13px;color:#333;margin-bottom:10px;font-weight:600}
.qrow{display:flex;gap:6px;margin-bottom:8px;align-items:center}
.qrow select,.qrow input{background:var(--gray);border:1px solid var(--border);color:#333;padding:7px 8px;border-radius:var(--r);font-size:11px;font-family:inherit;outline:none}
.qrow select:focus,.qrow input:focus{border-color:var(--blue)}
.qrow select{flex:1}
.qrow input{flex:2}
.rbox{background:var(--blue-light);border:1px solid rgba(43,125,233,.2);border-radius:var(--r);padding:12px;margin-top:12px;font-size:12px}
.rbox span{color:var(--blue);font-weight:600}
.mwrap{flex:1;position:relative;background:#e8eaed}
#mapCanvas{width:100%;height:100%;display:block;cursor:grab}
#mapCanvas:active{cursor:grabbing}
.mctrls{position:absolute;top:14px;right:14px;display:flex;flex-direction:column;gap:4px;z-index:50}
.mbtn{width:34px;height:34px;background:var(--white);border:1px solid var(--border);color:#555;border-radius:var(--r);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:all .15s;box-shadow:var(--shadow)}
.mbtn:hover{color:var(--blue);border-color:var(--blue);box-shadow:var(--shadow-lg)}
.mbtn.on{background:var(--blue);color:#fff;border-color:var(--blue)}
.zctrls{display:flex;flex-direction:column;gap:1px;border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow)}
.zctrls .mbtn{box-shadow:none;border:none;border-radius:0}
.mlegend{position:absolute;bottom:18px;right:14px;background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:12px 14px;z-index:50;min-width:140px;box-shadow:var(--shadow-lg)}
.mlegend h5{font-size:11px;color:var(--blue);margin-bottom:8px;font-weight:600;display:flex;align-items:center;gap:5px}
.legitem{display:flex;align-items:center;gap:6px;font-size:11px;padding:2px 0;color:#555}
.legcolor{width:14px;height:3px;border-radius:2px}
.sbar{display:flex;align-items:center;height:28px;padding:0 16px;background:var(--white);border-top:1px solid var(--border);font-size:11px;color:var(--gray-t);gap:14px}
.sitem{display:flex;align-items:center;gap:4px}
.sdot{width:6px;height:6px;border-radius:50%;background:var(--green)}
.sdot.loading{background:var(--orange);animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.sspace{flex:1}
.sbadge{background:var(--gray);padding:1px 6px;border-radius:8px;font-size:10px;font-weight:500;color:#333}
.db-badge{display:flex;align-items:center;gap:5px;padding:3px 8px;border-radius:8px;font-size:10px;font-weight:500}
.db-badge.connected{background:rgba(46,125,50,.08);color:var(--green)}
.db-badge.init{background:rgba(245,158,11,.08);color:var(--orange)}
.db-badge.disconnected{background:rgba(229,57,53,.08);color:var(--red)}
.ctx{position:fixed;background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:5px 0;z-index:2000;min-width:200px;box-shadow:var(--shadow-xl);display:none}
.ctx.show{display:block}
.ctxi{display:flex;align-items:center;gap:8px;padding:8px 14px;font-size:12px;cursor:pointer;color:#333;transition:background .1s}
.ctxi:hover{background:var(--blue-light);color:var(--blue)}
.ctxi i{width:14px;text-align:center;color:var(--gray-t);font-size:11px}
.ctxi:hover i{color:var(--blue)}
.ctxsep{height:1px;background:var(--border);margin:3px 0}
.moverlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:2000;display:none;align-items:center;justify-content:center}
.moverlay.show{display:flex}
.modal{background:var(--white);border-radius:var(--rl);width:540px;max-width:90vw;max-height:80vh;overflow:hidden;box-shadow:var(--shadow-xl)}
.mhdr{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border)}
.mhdr h3{font-size:15px;color:#333;font-weight:600}
.mclose{background:0 0;border:none;color:var(--gray-t);font-size:20px;cursor:pointer;padding:4px 6px;border-radius:4px;transition:all .15s}
.mclose:hover{background:var(--gray);color:#333}
.mbody{padding:18px;overflow-y:auto;max-height:55vh}
.mfoot{padding:12px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:6px}
.notif{position:fixed;top:66px;right:16px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:10px 16px;z-index:3000;font-size:12px;transform:translateX(120%);transition:transform .3s;box-shadow:var(--shadow-xl);display:flex;align-items:center;gap:6px}
.notif.show{transform:translateX(0)}
.notif.success{border-left:3px solid var(--green)}
.notif.error{border-left:3px solid var(--red)}
.loading{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.7);z-index:5000;display:none;align-items:center;justify-content:center;flex-direction:column;gap:12px}
.loading.show{display:flex}
.spinner{width:28px;height:28px;border:3px solid var(--border);border-top-color:var(--blue);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-size:13px;color:var(--gray-t)}
.importz{border:2px dashed var(--border);border-radius:var(--rl);padding:28px;text-align:center;cursor:pointer;transition:all .2s;background:var(--gray)}
.importz:hover{border-color:var(--blue);background:var(--blue-light)}
.importz i{font-size:32px;color:var(--gray-t);margin-bottom:10px}
.importz p{font-size:13px;color:var(--gray-t)}
.strow{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.strow label{font-size:12px;color:var(--gray-t);min-width:80px}
.strow input[type=color]{width:36px;height:30px;border:none;cursor:pointer;border-radius:4px;background:0 0}
.strow input[type=range]{flex:1;accent-color:var(--blue)}
.dinput{width:100%;background:var(--gray);border:1px solid var(--border);color:#333;padding:8px 10px;border-radius:var(--r);font-size:12px;font-family:inherit;margin-bottom:6px;outline:none}
.dinput:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(43,125,233,.1)}
.drawind{position:absolute;top:14px;left:50%;transform:translateX(-50%);background:var(--white);color:#333;padding:7px 16px;border-radius:16px;font-size:11px;z-index:50;display:none;box-shadow:var(--shadow-lg);border:1px solid var(--border);align-items:center;gap:6px;font-weight:500}
.drawind.show{display:flex}
.drawind i{color:var(--blue)}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:0 0}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
::-webkit-scrollbar-thumb:hover{background:#bbb}
.pg-panel{padding:14px}
.pg-panel h4{font-size:13px;color:#333;margin-bottom:10px;font-weight:600;display:flex;align-items:center;gap:6px}
.pg-panel h4 i{color:var(--blue)}
.pg-status{padding:10px;border-radius:var(--r);margin-bottom:12px;font-size:12px;display:flex;align-items:center;gap:6px}
.pg-status.connected{background:rgba(46,125,50,.08);border:1px solid rgba(46,125,50,.2);color:var(--green)}
.pg-status.init{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);color:var(--orange)}
.pg-status.error{background:rgba(229,57,53,.08);border:1px solid rgba(229,57,53,.2);color:var(--red)}
.pg-tables{max-height:280px;overflow-y:auto;margin-top:10px}
.pg-table-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:var(--r);cursor:pointer;transition:all .12s;border:1px solid var(--border);margin-bottom:3px}
.pg-table-item:hover{background:var(--blue-light);border-color:rgba(43,125,233,.3)}
.pg-t-icon{width:28px;height:28px;background:var(--blue-light);border-radius:5px;display:flex;align-items:center;justify-content:center;color:var(--blue);font-size:12px;flex-shrink:0}
.pg-t-info{flex:1;min-width:0}
.pg-t-name{font-size:12px;font-weight:500;color:#333;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pg-t-meta{font-size:10px;color:var(--gray-t)}
.pg-t-actions{display:none;gap:3px;flex-shrink:0}
.pg-table-item:hover .pg-t-actions{display:flex}
.pg-sql-area{width:100%;min-height:130px;background:var(--dark);color:#0f0;border:1px solid var(--border);border-radius:var(--r);padding:10px;font-family:'SF Mono',Consolas,monospace;font-size:12px;resize:vertical;outline:none;line-height:1.5}
.pg-sql-area:focus{border-color:var(--blue)}
.pg-sql-result{margin-top:10px;overflow-x:auto}
.pg-sql-result table{width:100%;border-collapse:collapse;font-size:11px}
.pg-sql-result th{background:var(--dark);color:#0f0;padding:6px 8px;text-align:left;font-size:10px;white-space:nowrap}
.pg-sql-result td{padding:5px 8px;border-bottom:1px solid var(--border);color:#333;font-family:monospace;font-size:10px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pg-sql-status{font-size:11px;color:var(--gray-t);margin-top:6px}
.pg-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:12px}
.pg-info-card{background:var(--gray);border-radius:var(--r);padding:10px;text-align:center}
.pg-info-card .pg-ic-value{font-size:18px;font-weight:700;color:var(--blue)}
.pg-info-card .pg-ic-label{font-size:10px;color:var(--gray-t);margin-top:2px}

/* Logout button in header */
.logout-btn{background:rgba(255,255,255,.1);border:none;color:rgba(255,255,255,.7);padding:6px 12px;border-radius:6px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:5px;transition:all .15s;margin-left:auto}
.logout-btn:hover{background:var(--red);color:#fff}
</style>
</head>
<body>

<!-- === AUTH OVERLAY === -->
<div class="auth-overlay" id="authOverlay">
  <div class="auth-card">
    <div class="auth-header">
      <div class="logo"><i class="fas fa-globe-americas"></i> WebGIS <small>Авторизация</small></div>
    </div>
    <div class="auth-body">
      <div class="auth-title">Вход в систему</div>
      <form class="auth-form" id="authForm">
        <div class="auth-input-group">
          <input type="text" class="auth-input" id="authLogin" placeholder="Логин или email" autocomplete="username" required>
