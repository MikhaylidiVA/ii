// ==================== GLOBALS & API CONFIG ====================
const API_BASE = '/api';

async function apiFetch(endpoint, options = {}) {
  // Добавляем auth заголовки если пользователь авторизован
  const headers = {
    'Content-Type': 'application/json',
    ...options.headers,
    ...Auth.getAuthHeaders()
  };
  
  const config = { 
    headers, 
    method: options.method || 'GET' 
  };
  if (options.body) config.body = JSON.stringify(options.body);
  
  try {
    const response = await fetch(`${API_BASE}${endpoint}`, config);
    
    // Обработка 401 - сессия истекла
    if (response.status === 401) {
      Auth.logout();
      throw new Error('Сессия истекла. Пожалуйста, войдите снова.');
    }
    
    const data = await response.json();
    if (!response.ok) throw new Error(data.error || 'API error');
    return data;
  } catch (e) {
    if (e.message.includes('Failed to fetch')) {
      throw new Error('Нет соединения с сервером');
    }
    throw e;
  }
}

let pgdb = null, pgReady = false, pgError = null;

const GISDB = {
  layers: {}, order: [], id: 1,
  init() {
    const s = localStorage.getItem('gisdb5');
    if (s) { try { const d = JSON.parse(s); this.layers = d.layers||{}; this.order = d.order||[]; this.id = d.id||1; } catch(e){} }
    if (!Object.keys(this.layers).length) this.seed();
  },
  save() { localStorage.setItem('gisdb5', JSON.stringify({layers:this.layers,order:this.order,id:this.id})); },
  add(name,type,features,color,source='local') {
    const id = 'l'+(this.id++);
    this.layers[id] = {id,name,type,features:features||[],color:color||'#2b7de9',visible:true,opacity:1,source};
    this.order.push(id); this.save(); return id;
  },
  remove(id) { delete this.layers[id]; this.order = this.order.filter(x=>x!==id); this.save(); },
  update(id,p) { if(this.layers[id]) Object.assign(this.layers[id],p); this.save(); },
  get(id) { return this.layers[id]; },
  visible() { return this.order.filter(id=>this.layers[id]&&this.layers[id].visible).map(id=>this.layers[id]); },
  total() { let n=0; for(const l of Object.values(this.layers)) n+=l.features.length; return n; },
  seed() {
    this.add('Города России','Point',[{type:'Feature',id:'f1',geometry:{type:'Point',coordinates:[37.6173,55.7558]},properties:{name:'Москва',population:12632409,type:'city',category:'Город'}}],'#2b7de9');
    this.save();
  }
};

// ==================== MAP ENGINE ====================
const Map = {
  canvas:null,ctx:null,center:{lat:55.75,lng:49.12},zoom:5,tileSize:256,
  dragging:false,dragStart:{x:0,y:0},dragCenter:{lat:0,lng:0},
  tiles:{},drawMode:null,drawPoints:[],measureMode:false,measurePoints:[],
  basemap:0,
  basemaps:[
    {name:'Схема',url:'https://core-renderer-tiles.maps.yandex.net/tiles?l=map&v=4.55.0&x={x}&y={y}&z={z}&scale=1&lang=ru_RU'},
    {name:'Спутник',url:'https://core-sat.maps.yandex.net/tiles?l=sat&v=3.2008.0&x={x}&y={y}&z={z}&scale=1&lang=ru_RU'},
    {name:'Гибрид',url:'https://core-sat.maps.yandex.net/tiles?l=sat&v=3.2008.0&x={x}&y={y}&z={z}&scale=1&lang=ru_RU'}
  ],
  ctxLatLng:null,selectedFeature:null,selectedLayerId:null,hoveredFeature:null,w:0,h:0,drawMouseLat:null,drawMouseLng:null,

  init(){
    this.canvas=document.getElementById('mapCanvas');
    this.ctx=this.canvas.getContext('2d');
    this.resize(); window.addEventListener('resize',()=>this.resize());
    this.bindEvents(); this.render();
  },
  resize(){
    const wrap=this.canvas.parentElement; const dpr=window.devicePixelRatio||1;
    this.w=wrap.clientWidth; this.h=wrap.clientHeight;
    this.canvas.width=this.w*dpr; this.canvas.height=this.h*dpr;
    this.canvas.style.width=this.w+'px'; this.canvas.style.height=this.h+'px';
    this.ctx.setTransform(dpr,0,0,dpr,0,0); this.render();
  },
  ll2px(lat,lng){const s=Math.pow(2,this.zoom);const x=(lng+180)/360*s*this.tileSize;const r=lat*Math.PI/180;const y=(1-Math.log(Math.tan(r)+1/Math.cos(r))/Math.PI)/2*s*this.tileSize;return{x,y};},
  px2ll(px,py){const s=Math.pow(2,this.zoom);const lng=px/(this.tileSize*s)*360-180;const n=Math.PI-2*Math.PI*py/(this.tileSize*s);const lat=180/Math.PI*Math.atan(0.5*(Math.exp(n)-Math.exp(-n)));return{lat,lng};},
  cp(){return this.ll2px(this.center.lat,this.center.lng);},
  render(){this.loadTiles();this.ctx.clearRect(0,0,this.w,this.h);this.drawTiles();this.drawFeatures();this.drawMeasure();this.drawPreview();},
  loadTiles(){
    const cp=this.cp();const cx=this.w/2-cp.x,cy=this.h/2-cp.y;
    const minTX=Math.floor(-cx/this.tileSize)-1,maxTX=Math.ceil((this.w-cx)/this.tileSize)+1;
    const minTY=Math.floor(-cy/this.tileSize)-1,maxTY=Math.ceil((this.h-cy)/this.tileSize)+1;
    const scale=Math.pow(2,this.zoom);const maxTY2=scale-1;
    for(let tx=minTX;tx<=maxTX;tx++){for(let ty=minTY;ty<=maxTY;ty++){
      const key=this.zoom+'_'+tx+'_'+ty;
      if(!this.tiles[key]){
        const wtx=((tx%scale)+scale)%scale;const wty=Math.max(0,Math.min(maxTY2,ty));
        const url=this.basemaps[this.basemap].url.replace('{x}',wtx).replace('{y}',wty).replace('{z}',this.zoom);
        const img=new Image();img.crossOrigin='anonymous';
        img.onload=()=>{this.tiles[key]={img,tx,ty};this.render();};
        img.onerror=()=>{this.tiles[key]={img:null,tx,ty};};
        img.src=url;this.tiles[key]={img:null,tx,ty,loading:true};
      }
    }}
  },
  drawTiles(){
    const cp=this.cp();const cx=this.w/2-cp.x,cy=this.h/2-cp.y;
    this.ctx.fillStyle='#e8eaed';this.ctx.fillRect(0,0,this.w,this.h);
    for(const key in this.tiles){const t=this.tiles[key];if(!t.img)continue;this.ctx.drawImage(t.img,t.tx*this.tileSize+cx,t.ty*this.tileSize+cy,this.tileSize,this.tileSize);}
  },
  drawFeatures(){
    const cp=this.cp();const cx=this.w/2-cp.x,cy=this.h/2-cp.y;
    for(const layer of GISDB.visible()){
      for(const f of layer.features){
        const geo=f.geometry;if(!geo)continue;const color=layer.color;
        const isSel=this.selectedFeature&&this.selectedFeature.id===f.id;
        const isHov=this.hoveredFeature&&this.hoveredFeature.id===f.id;const active=isSel||isHov;
        this.ctx.save();if(active){this.ctx.shadowColor=color;this.ctx.shadowBlur=isSel?15:10;}
        if(geo.type==='Point'){
          const p=this.ll2px(geo.coordinates[1],geo.coordinates[0]);const x=p.x+cx,y=p.y+cy;
          this.ctx.beginPath();this.ctx.arc(x,y,isSel?9:7,0,Math.PI*2);this.ctx.fillStyle=color;this.ctx.fill();
          this.ctx.strokeStyle='#fff';this.ctx.lineWidth=2.5;this.ctx.stroke();
          if(active){this.ctx.beginPath();this.ctx.arc(x,y,13,0,Math.PI*2);this.ctx.strokeStyle=color;this.ctx.lineWidth=1.5;this.ctx.globalAlpha=0.4;this.ctx.stroke();this.ctx.globalAlpha=1;}
          if(this.zoom>=6&&f.properties.name){this.ctx.shadowBlur=0;this.ctx.font='600 11px Inter,sans-serif';this.ctx.fillStyle='#333';this.ctx.fillText(f.properties.name,x+12,y+4);}
        }else if(geo.type==='LineString'){
          this.ctx.beginPath();this.ctx.strokeStyle=color;this.ctx.lineWidth=isSel?4:3;this.ctx.lineJoin='round';this.ctx.lineCap='round';
          for(let i=0;i<geo.coordinates.length;i++){const p=this.ll2px(geo.coordinates[i][1],geo.coordinates[i][0]);if(i===0)this.ctx.moveTo(p.x+cx,p.y+cy);else this.ctx.lineTo(p.x+cx,p.y+cy);}
          this.ctx.stroke();
        }else if(geo.type==='Polygon'||geo.type==='MultiPolygon'){
          const rings=geo.type==='MultiPolygon'?geo.coordinates.map(p=>p[0]):[geo.coordinates[0]];
          for(const ring of rings){
            this.ctx.beginPath();for(let i=0;i<ring.length;i++){const p=this.ll2px(ring[i][1],ring[i][0]);if(i===0)this.ctx.moveTo(p.x+cx,p.y+cy);else this.ctx.lineTo(p.x+cx,p.y+cy);}
            this.ctx.closePath();this.ctx.fillStyle=color+'22';this.ctx.fill();this.ctx.strokeStyle=color;this.ctx.lineWidth=isSel?3:2;this.ctx.stroke();
          }
        }
        this.ctx.restore();
      }
    }
  },
  drawMeasure(){
    if(!this.measureMode||this.measurePoints.length<2)return;
    const cp=this.cp();const cx=this.w/2-cp.x,cy=this.h/2-cp.y;
    this.ctx.save();this.ctx.strokeStyle='#2e7d32';this.ctx.lineWidth=2;this.ctx.setLineDash([6,4]);
    this.ctx.beginPath();for(let i=0;i<this.measurePoints.length;i++){const p=this.ll2px(this.measurePoints[i].lat,this.measurePoints[i].lng);if(i===0)this.ctx.moveTo(p.x+cx,p.y+cy);else this.ctx.lineTo(p.x+cx,p.y+cy);}
    this.ctx.stroke();this.ctx.setLineDash([]);
    for(const pt of this.measurePoints){const p=this.ll2px(pt.lat,pt.lng);this.ctx.beginPath();this.ctx.arc(p.x+cx,p.y+cy,4,0,Math.PI*2);this.ctx.fillStyle='#fff';this.ctx.fill();this.ctx.strokeStyle='#2e7d32';this.ctx.lineWidth=2;this.ctx.stroke();}
    if(this.measurePoints.length>1){let total=0;for(let i=1;i<this.measurePoints.length;i++){total+=turf.distance(turf.point([this.measurePoints[i-1].lng,this.measurePoints[i-1].lat]),turf.point([this.measurePoints[i].lng,this.measurePoints[i].lat]),{units:'km'});}
    const last=this.measurePoints[this.measurePoints.length-1];const lp=this.ll2px(last.lat,last.lng);this.ctx.font='600 12px Inter';this.ctx.fillStyle='#2e7d32';this.ctx.fillText(total.toFixed(2)+' км',lp.x+cx+10,lp.y+cy-10);}
    this.ctx.restore();
  },
  drawPreview(){
    if(!this.drawMode)return;const cp=this.cp();const cx=this.w/2-cp.x,cy=this.h/2-cp.y;
    this.ctx.save();this.ctx.strokeStyle='#2b7de9';this.ctx.fillStyle='rgba(43,125,233,0.1)';this.ctx.lineWidth=2;this.ctx.setLineDash([5,3]);
    if(this.drawMode==='line'&&this.drawPoints.length>0){this.ctx.beginPath();for(let i=0;i<this.drawPoints.length;i++){const p=this.ll2px(this.drawPoints[i].lat,this.drawPoints[i].lng);if(i===0)this.ctx.moveTo(p.x+cx,p.y+cy);else this.ctx.lineTo(p.x+cx,p.y+cy);}if(this.drawMouseLat!==null){const p=this.ll2px(this.drawMouseLat,this.drawMouseLng);this.ctx.lineTo(p.x+cx,p.y+cy);}this.ctx.stroke();}
    else if(this.drawMode==='poly'&&this.drawPoints.length>0){this.ctx.beginPath();for(let i=0;i<this.drawPoints.length;i++){const p=this.ll2px(this.drawPoints[i].lat,this.drawPoints[i].lng);if(i===0)this.ctx.moveTo(p.x+cx,p.y+cy);else this.ctx.lineTo(p.x+cx,p.y+cy);}if(this.drawMouseLat!==null){const p=this.ll2px(this.drawMouseLat,this.drawMouseLng);this.ctx.lineTo(p.x+cx,p.y+cy);}this.ctx.closePath();this.ctx.fill();this.ctx.stroke();}
    for(const pt of this.drawPoints){const p=this.ll2px(pt.lat,pt.lng);this.ctx.beginPath();this.ctx.arc(p.x+cx,p.y+cy,5,0,Math.PI*2);this.ctx.fillStyle='#2b7de9';this.ctx.fill();this.ctx.strokeStyle='#fff';this.ctx.lineWidth=2;this.ctx.stroke();}
    this.ctx.restore();
  },
  s2ll(sx,sy){const cp=this.cp();const px=sx-this.w/2+cp.x,py=sy-this.h/2+cp.y;return this.px2ll(px,py);},
  findAt(sx,sy){
    const ll=this.s2ll(sx,sy);const threshold=12/Math.pow(2,this.zoom-10);
    for(const layer of GISDB.visible()){for(const f of layer.features){const geo=f.geometry;if(!geo)continue;if(geo.type==='Point'){const dx=geo.coordinates[0]-ll.lng,dy=geo.coordinates[1]-ll.lat;if(Math.sqrt(dx*dx+dy*dy)<threshold*3)return{feature:f,layerId:layer.id};}}}
    for(const layer of GISDB.visible()){for(const f of layer.features){const geo=f.geometry;if(!geo)continue;try{const pt=turf.point([ll.lng,ll.lat]);if(geo.type==='Polygon'||geo.type==='MultiPolygon'){const coords=geo.type==='MultiPolygon'?geo.coordinates[0][0]:geo.coordinates[0];if(turf.booleanPointInPolygon(pt,turf.polygon([coords])))return{feature:f,layerId:layer.id};}else if(geo.type==='LineString'){const dist=turf.pointToLineDistance(pt,turf.lineString(geo.coordinates),{units:'km'});if(dist<threshold*0.3)return{feature:f,layerId:layer.id};}}catch(e){}}}
    return null;
  },
  zoomAt(sx,sy,delta){const old=this.zoom;this.zoom=Math.max(2,Math.min(18,this.zoom+delta));if(old!==this.zoom){const ll=this.s2ll(sx,sy);this.center={lat:ll.lat,lng:ll.lng};this.render();}},
  finishDraw(){
    if(this.drawMode==='line'&&this.drawPoints.length>=2){const coords=this.drawPoints.map(p=>[p.lng,p.lat]);App.addFeatureToLayer({type:'Feature',geometry:{type:'LineString',coordinates:coords},properties:{name:'Линия',type:'manual',created:new Date().toISOString()}},'Line');}
    else if(this.drawMode==='poly'&&this.drawPoints.length>=3){const coords=[this.drawPoints.map(p=>[p.lng,p.lat])];coords[0].push(coords[0][0]);App.addFeatureToLayer({type:'Feature',geometry:{type:'Polygon',coordinates:coords},properties:{name:'Полигон',type:'manual',created:new Date().toISOString()}},'Polygon');}
    this.drawPoints=[];this.drawMode=null;this.drawMouseLat=null;this.drawMouseLng=null;
    document.getElementById('drawInd').classList.remove('show');this.render();App.updateUI();
  },
  bindEvents(){
    this.canvas.addEventListener('mousedown',e=>{if(this.drawMode==='line'||this.drawMode==='poly'){const ll=this.s2ll(e.offsetX,e.offsetY);this.drawPoints.push({lat:ll.lat,lng:ll.lng});return;}this.dragging=true;this.dragStart={x:e.offsetX,y:e.offsetY};this.dragCenter={...this.center};});
    this.canvas.addEventListener('mousemove',e=>{const ll=this.s2ll(e.offsetX,e.offsetY);document.getElementById('cLat').textContent=ll.lat.toFixed(4);document.getElementById('cLng').textContent=ll.lng.toFixed(4);if(this.drawMode==='line'||this.drawMode==='poly'){this.drawMouseLat=ll.lat;this.drawMouseLng=ll.lng;this.render();return;}if(this.dragging){const dx=e.offsetX-this.dragStart.x,dy=e.offsetY-this.dragStart.y;const cp1=this.ll2px(this.dragCenter.lat,this.dragCenter.lng);const cp2=this.px2ll(cp1.x-dx,cp1.y-dy);this.center={lat:cp2.lat,lng:cp2.lng};this.render();}const hit=this.findAt(e.offsetX,e.offsetY);if(hit){this.hoveredFeature=hit.feature;this.canvas.style.cursor='pointer';this.render();}else{this.hoveredFeature=null;this.canvas.style.cursor=this.dragging?'grabbing':'grab';this.render();}});
    this.canvas.addEventListener('mouseup',()=>{this.dragging=false;});
    this.canvas.addEventListener('mouseleave',()=>{this.dragging=false;});
    this.canvas.addEventListener('dblclick',e=>{if(this.drawMode==='line'||this.drawMode==='poly'){this.finishDraw();return;}const ll=this.s2ll(e.offsetX,e.offsetY);this.center={lat:ll.lat,lng:ll.lng};this.zoom=Math.min(this.zoom+1,18);this.render();});
    this.canvas.addEventListener('wheel',e=>{e.preventDefault();this.zoomAt(e.offsetX,e.offsetY,e.deltaY>0?-1:1);},{passive:false});
    this.canvas.addEventListener('contextmenu',e=>{e.preventDefault();this.ctxLatLng=this.s2ll(e.offsetX,e.offsetY);App.showCtx(e.clientX,e.clientY);});
    this.canvas.addEventListener('click',e=>{if(this.drawMode==='point'){const ll=this.s2ll(e.offsetX,e.offsetY);App.addPointFeature(ll.lat,ll.lng);return;}if(this.measureMode){const ll=this.s2ll(e.offsetX,e.offsetY);this.measurePoints.push(ll);if(this.measurePoints.length>1){let total=0;for(let i=1;i<this.measurePoints.length;i++){total+=turf.distance(turf.point([this.measurePoints[i-1].lng,this.measurePoints[i-1].lat]),turf.point([this.measurePoints[i].lng,this.measurePoints[i].lat]),{units:'km'});}App.notify('Расстояние: '+total.toFixed(2)+' км','success');}this.render();return;}const hit=this.findAt(e.offsetX,e.offsetY);if(hit)App.selectFeature(hit.feature,hit.layerId);else App.deselectAll();});
    document.addEventListener('click',()=>App.hideCtx());
    document.addEventListener('keydown',e=>{if(e.key==='Escape'){if(this.drawMode)document.getElementById('bCancelDraw').click();if(this.measureMode){this.measureMode=false;this.measurePoints=[];this.render();document.getElementById('bMeasure').classList.remove('active');}App.hideModal();}});
  }
};

// ==================== DB API FUNCTIONS ====================
async function initRealPG() {
  if (!Auth.isAuthenticated()) return;
  
  showLoading('Подключение к серверу...');
  try {
    const stats = await apiFetch('/stats');
    pgReady = true; pgError = null;
    document.getElementById('statusDot').className = 'sdot';
    document.getElementById('statusText').textContent = 'PostgreSQL (сервер)';
    document.getElementById('pgBadge').className = 'db-badge connected';
    document.getElementById('pgBadgeText').textContent = `БД: ${stats.dbSize}`;
    document.getElementById('dbLabel').textContent = 'PostgreSQL';
    hideLoading();
    App.notify('Подключено к серверной БД', 'success');
    App.renderPostGISPanel();
  } catch (e) {
    pgError = e.message;
    document.getElementById('pgBadge').className = 'db-badge error';
    document.getElementById('pgBadgeText').textContent = 'Ошибка подключения';
    hideLoading();
    App.notify('Ошибка: ' + e.message, 'error');
    App.renderPostGISPanel();
  }
}

async function loadLayerFromPG(layerId, layerName, geoType, color) {
  showLoading('Загрузка из БД...');
  try {
    const data = await apiFetch(`/layers/${layerId}/features`);
    const features = data.features.map(f => ({...f, properties: {...f.properties, source: 'postgresql'}}));
    const lid = GISDB.add('PG: ' + layerName, geoType === 'LINESTRING' ? 'Line' : geoType === 'POLYGON' ? 'Polygon' : 'Point', features, color, 'postgresql');
    hideLoading(); App.updateUI(); Map.render(); App.zoomToLayer(lid);
    App.notify(`Загружено ${features.length} объектов`, 'success'); return lid;
  } catch (e) { hideLoading(); App.notify('Ошибка: ' + e.message, 'error'); return null; }
}

async function executePGSQL(sql) {
  try {
    const result = await apiFetch('/sql', { method: 'POST', body: { sql } });
    return { results: [{ command: 'SELECT', rows: result.rows, fields: result.rows[0] ? Object.keys(result.rows[0]).map(n=>({name:n})) : [] }] };
  } catch (e) { return { error: e.message }; }
}

async function insertFeatureToPG(layerName, geomType, coordinates, properties) {
  try {
    let layers = await apiFetch('/layers');
    let layer = layers.find(l => l.name === layerName);
    let layerId = layer ? layer.id : (await apiFetch('/layers', { method:'POST', body:{ name:layerName, layer_type: geomType==='Point'?'Point':geomType==='Line'?'LineString':'Polygon', color:'#2b7de9' } })).id;
    let geometry = geomType==='Point' ? {type:'Point',coordinates} : geomType==='Line' ? {type:'LineString',coordinates} : {type:'Polygon',coordinates:[coordinates]};
    await apiFetch(`/layers/${layerId}/features`, { method:'POST', body:{ geometry, properties:{...properties, source:'postgresql'} } });
    return { success: true };
  } catch (e) { return { error: e.message }; }
}

async function getPGTables() { try { return await apiFetch('/layers'); } catch(e) { return []; } }
async function getPGStats() { try { return await apiFetch('/stats'); } catch(e) { return null; } }
async function deleteFeatureFromPG(pgid) { await apiFetch(`/features/${pgid}`, { method:'DELETE' }); }
async function deleteLayerFromPG(layerId) { await apiFetch(`/layers/${layerId}`, { method:'DELETE' }); }

function showLoading(text) { document.getElementById('loadText').textContent = text || 'Загрузка...'; document.getElementById('load').classList.add('show'); }
function hideLoading() { document.getElementById('load').classList.remove('show'); }

// ==================== APP ====================
const App = {
