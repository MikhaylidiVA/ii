  async loadPGFromDB(layerId, name, layerType, color) { const geoType = layerType === 'LINESTRING' ? 'Line' : layerType === 'POLYGON' || layerType === 'MULTIPOLYGON' ? 'Polygon' : 'Point'; await loadLayerFromPG(layerId, name, geoType, color); },
  
  async delPGTable(layerId, name) { if (!confirm('Удалить "' + name + '" из PostgreSQL?')) return; showLoading('Удаление из PostgreSQL...'); await deleteLayerFromPG(layerId); hideLoading(); this.renderPostGISPanel(); this.notify('Удалено из PostgreSQL', 'success'); },
  
  async exportToPG() {
