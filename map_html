    sessionStorage.removeItem(AUTH_CONFIG.USER_KEY);
    
    this.token = null;
    this.currentUser = null;
    
    // Перезагрузка страницы для полного сброса состояния
    location.reload();
  },
  
  updateUserInfo() {
    if (this.currentUser) {
      document.getElementById('userInfo').innerHTML = 
        `<span style="font-size:10px;color:var(--gray-t)">👤 ${this.currentUser.name || this.currentUser.login}</span>`;
    }
  },
  
  getAuthHeaders() {
    return {
      'Authorization': `Bearer ${this.token}`,
      'Content-Type': 'application/json'
    };
  },
  
  isAuthenticated() {
    return !!this.token && !!this.currentUser;
