  execQuery() {
    const lid = document.getElementById('qL').value; const field = document.getElementById('qF').value; const op = document.getElementById('qOp').value; const val = document.getElementById('qV').value;
    if (!lid || field === 'Поле') { this.notify('Выберите слой и поле', 'error'); return; }
    const features = GISDB.get(lid).features;
    const res = features.filter(f => { const fv = (f.properties||{})[field]; if (op === 'contains') return String(fv).toLowerCase().includes(val.toLowerCase()); if (op === '!=') return String(fv) !== val; if (['>','<'].includes(op)) return parseFloat(fv) + op + parseFloat(val); return String(fv) === val; });
    const box = document.getElementById('qRes'); box.style.display = 'block'; box.innerHTML = '<p>Найдено: <span>' + res.length + '</span> из <span>' + features.length + '</span></p><div style="max-height:150px;overflow-y:auto;margin-top:6px;">' + res.map(f => '<p style="padding:2px 0;font-size:11px;">' + ((f.properties||{}).name || '—') + '</p>').join('') + '</div>'; this.notify('Найдено ' + res.length, 'success');
  },
  
  execSpatial() {
    const l1id = document.getElementById('spL1').value; const l2id = document.getElementById('spL2').value; const op = document.getElementById('spOp').value;
    if (!l1id || !l2id) { this.notify('Выберите оба слоя', 'error'); return; }
    const f1s = GISDB.get(l1id).features, f2s = GISDB.get(l2id).features; let res = [];
    f1s.forEach(a => f2s.forEach(b => { try { let hit = false; if (op === 'intersects') hit = turf.booleanIntersects(turf.feature(a.geometry), turf.feature(b.geometry)); else if (op === 'contains') hit = turf.booleanContains(turf.feature(a.geometry), turf.feature(b.geometry)); if (hit) res.push({a: (a.properties||{}).name, b: (b.properties||{}).name}); } catch(e) {} }));
    const box = document.getElementById('spRes'); box.style.display = 'block'; box.innerHTML = '<p>Результат: <span>' + res.length + '</span> пересечений</p><div style="max-height:120px;overflow-y:auto;margin-top:6px;">' + res.map(r => '<p style="padding:2px 0;font-size:11px;">' + r.a + ' ↔ ' + r.b + '</p>').join('') + '</div>'; this.notify(res.length + ' пересечений', 'success');
  },
  
