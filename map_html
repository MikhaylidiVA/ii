    document.getElementById('bCancelDraw').onclick = () => { Map.drawMode = null; Map.drawPoints = []; Map.drawMouseLat = null; Map.drawMouseLng = null; document.getElementById('drawInd').classList.remove('show'); Map.render(); };
    document.getElementById('bBuffer').onclick = () => { if (!Map.selectedFeature) { this.notify('Выберите объект', 'error'); return; } this.showModal('Буферная зона', '<div style="display:flex;flex-direction:column;gap:8px;"><label style="font-size:10px;color:var(--gray-t);">Радиус (км)</label><input type="number" class="dinput" id="bufR" value="10" min="0.1" step="0.1"><div class="strow"><label>Цвет</label><input type="color" id="bufC" value="#2b7de9"></div></div>', '<button class="btn btn-s" onclick="App.hideModal()">Отмена</button><button class="btn btn-p" onclick="App.createBuffer()">Создать</button>'); };
    document.getElementById('bIntersect').onclick = () => { const layers = GISDB.order.map(id => { const l = GISDB.get(id); return '<option value="' + id + '">' + l.name + '</option>'; }).join(''); this.showModal('Пересечение слоёв', '<div class="qrow"><select id="iL1" style="flex:1;background:var(--gray);border:1px solid var(--border);color:#333;padding:7px;border-radius:var(--r);font-size:11px;">' + layers + '</select><span style="color:var(--gray-t);padding:0 6px;font-size:16px;">∩</span><select id="iL2" style="flex:1;background:var(--gray);border:1px solid var(--border);color:#333;padding:7px;border-radius:var(--r);font-size:11px;">' + layers + '</select></div>', '<button class="btn btn-s" onclick="App.hideModal()">Отмена</button><button class="btn btn-p" onclick="App.runIntersect()">Вычислить</button>'); };
    document.getElementById('bPG').onclick = () => { document.querySelectorAll('.tbtn').forEach(b => b.classList.remove('on')); document.querySelectorAll('.tcontent').forEach(c => c.classList.remove('on')); document.querySelector('[data-t="postgis"]').classList.add('on'); document.getElementById('t-postgis').classList.add('on'); this.renderPostGISPanel(); };
    document.getElementById('bPGSQL').onclick = () => { this.runPGSQLModal(); };
    document.getElementById('bRefreshDB').onclick = () => { this.renderPostGISPanel(); };
    document.getElementById('bStyle').onclick = () => { if (!Map.selectedLayerId) { this.notify('Выберите слой', 'error'); return; } const l = GISDB.get(Map.selectedLayerId); this.showModal('Стиль слоя', '<div class="strow"><label>Цвет</label><input type="color" id="stC" value="' + l.color + '"></div><div class="strow"><label>Прозрачность</label><input type="range" id="stO" min="0" max="1" step="0.1" value="' + l.opacity + '"></div>', '<button class="btn btn-s" onclick="App.hideModal()">Отмена</button><button class="btn btn-p" onclick="App.applyStyle()">Применить</button>'); };
    document.getElementById('xCtxPt').onclick = () => { Map.hideCtx(); this.addPointFeature(Map.ctxLatLng.lat, Map.ctxLatLng.lng); this.updateUI(); };
    document.getElementById('xSavePG').onclick = () => { Map.hideCtx(); if (Map.selectedFeature) this.saveToPG(); else this.notify('Выберите объект', 'error'); };
    document.getElementById('xCtr').onclick = () => { Map.hideCtx(); Map.center = {lat: Map.ctxLatLng.lat, lng: Map.ctxLatLng.lng}; Map.render(); };
    document.getElementById('xCop').onclick = () => { Map.hideCtx(); const c = Map.ctxLatLng.lat.toFixed(6) + ', ' + Map.ctxLatLng.lng.toFixed(6); navigator.clipboard.writeText(c).then(() => this.notify('Скопировано', 'success')); };
    document.getElementById('xDel').onclick = () => { Map.hideCtx(); this.delFeature(); };
    document.getElementById('xProp').onclick = () => { Map.hideCtx(); document.getElementById('bProps').click(); };
    document.getElementById('mCls').onclick = () => this.hideModal();
    document.getElementById('mOv').onclick = e => { if (e.target === e.currentTarget) this.hideModal(); };
    document.getElementById('searchIn').onkeydown = e => { if (e.key === 'Enter') this.search(); };
    document.getElementById('aSel').onchange = () => this.renderAttrTable();
    document.getElementById('bExpTbl').onclick = () => document.getElementById('bExport').click();
    document.getElementById('bExecQ').onclick = () => this.execQuery();
    document.getElementById('bClearQ').onclick = () => { document.getElementById('qV').value = ''; document.getElementById('qRes').style.display = 'none'; };
    document.getElementById('bSpQ').onclick = () => this.execSpatial();
    document.getElementById('bMeasure').onclick = function() { Map.measureMode = !Map.measureMode; Map.measurePoints = []; this.classList.toggle('on', Map.measureMode); if (Map.measureMode) App.notify('Кликайте для измерения', 'success'); Map.render(); };
    document.getElementById('bBase').onclick = () => { Map.basemap = (Map.basemap + 1) % Map.basemaps.length; Map.tiles = {}; Map.render(); this.notify('Подложка: ' + Map.basemaps[Map.basemap].name, 'success'); };
    document.getElementById('bLoc').onclick = () => { if (navigator.geolocation) { navigator.geolocation.getCurrentPosition(p => { Map.center = {lat: p.coords.latitude, lng: p.coords.longitude}; Map.zoom = 14; Map.render(); App.notify('Местоположение найдено', 'success'); }, () => App.notify('Не удалось определить', 'error')); } };
  },
  
  createLayer() { const name = document.getElementById('nln').value || 'Новый слой'; const type = document.getElementById('nlt').value; const color = document.getElementById('nlc').value; GISDB.add(name, type, [], color); this.hideModal(); this.updateUI(); Map.render(); this.notify('Слой "' + name + '" создан', 'success'); },
  
  handleImport(input) { const f = input.files[0]; if (f) this.processImport(f); },
  
  processImport(file) { const reader = new FileReader(); reader.onload = e => { try { const geo = JSON.parse(e.target.result); const name = document.getElementById('impName')?.value || file.name.replace(/\.[^.]+$/, ''); let type = 'Point'; if (geo.features && geo.features.length) type = geo.features[0].geometry?.type || 'Point'; if (type === 'LineString') type = 'Line'; const features = (geo.features || []).map(f => ({...f, id: f.id || 'f_' + Date.now() + '_' + Math.random().toString(36).substr(2,5)})); GISDB.add(name, type, features, '#2e7d32'); this.hideModal(); this.updateUI(); Map.render(); this.notify('Импортировано ' + features.length + ' объектов', 'success'); } catch (err) { this.notify('Ошибка: ' + err.message, 'error'); } }; reader.readAsText(file); },
  
  createBuffer() { const r = parseFloat(document.getElementById('bufR').value); const c = document.getElementById('bufC').value; const f = Map.selectedFeature; try { const buf = turf.buffer(turf.feature(f.geometry), r, {units: 'kilometers'}); const feat = {type: 'Feature', geometry: buf.geometry, properties: {name: 'Буфер ' + r + 'км', radius: r}}; GISDB.add('Буфер ' + r + 'км', 'Polygon', [feat], c); this.hideModal(); this.updateUI(); Map.render(); this.notify('Буфер создан', 'success'); } catch (e) { this.notify('Ошибка: ' + e.message, 'error'); } },
  
  runIntersect() { const l1 = GISDB.get(document.getElementById('iL1').value); const l2 = GISDB.get(document.getElementById('iL2').value); if (!l1 || !l2) { this.notify('Выберите оба слоя', 'error'); return; } const res = []; l1.features.forEach(a => { if (a.geometry.type !== 'Polygon') return; l2.features.forEach(b => { if (b.geometry.type !== 'Polygon') return; try { const i = turf.intersect(turf.feature(a.geometry), turf.feature(b.geometry)); if (i) res.push(i); } catch(e) {} }); }); if (res.length) { GISDB.add('Пересечение', 'Polygon', res, '#e53935'); this.hideModal(); this.updateUI(); Map.render(); this.notify(res.length + ' пересечений', 'success'); } else { this.hideModal(); this.notify('Пересечений не найдено', 'error'); } },
  
  applyStyle() { const l = GISDB.get(Map.selectedLayerId); if (!l) return; l.color = document.getElementById('stC').value; l.opacity = parseFloat(document.getElementById('stO').value); GISDB.save(); this.hideModal(); this.renderLayerList(); this.renderLegend(); Map.render(); this.notify('Стиль применён', 'success'); },
  
  search() { const q = document.getElementById('searchIn').value.toLowerCase().trim(); if (!q) return; let f = null; for (const id of GISDB.order) { const feats = GISDB.get(id).features; for (const feat of feats) { if ((feat.properties.name || '').toLowerCase().includes(q)) { f = feat; break; } } if (f) break; } if (f) { this.selectFeature(f, null); this.zoomTo(); this.notify('Найдено: ' + f.properties.name, 'success'); } else this.notify('Не найдено', 'error'); }
};

// ==================== INIT ====================
document.addEventListener('DOMContentLoaded', () => {
  App.init();
});
</script>
