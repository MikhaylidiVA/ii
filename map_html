  runPGSQLModal() { this.showModal('PostgreSQL SQL — Выполнение запросов', '<div style="margin-bottom:8px;display:flex;gap:6px;"><button class="btn btn-s btn-sm" onclick="App.pgSQLTemplates()"><i class="fas fa-file-code"></i> Шаблоны</button><button class="btn btn-s btn-sm" onclick="App.pgSQLHelp()"><i class="fas fa-circle-question"></i> Справка</button></div><textarea class="pg-sql-area" id="pgSQLArea" spellcheck="false" placeholder="-- Введите SQL запрос\nSELECT l.name, COUNT(f.id) as cnt\nFROM gis_layers l\nLEFT JOIN gis_features f ON l.id = f.layer_id\nGROUP BY l.id, l.name;"></textarea><div style="margin-top:8px;display:flex;gap:6px;"><button class="btn btn-p btn-sm" onclick="App.runPGSQL()"><i class="fas fa-play"></i> Выполнить</button></div><div class="pg-sql-result" id="pgSQLRes"></div>', ''); },
  
  async runPGSQL() {
