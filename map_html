    const qL = document.getElementById('qL'); if (qL) qL.onchange = function() { const layer = GISDB.get(this.value); const fs = document.getElementById('qF'); fs.innerHTML = '<option>Поле</option>'; if (layer && layer.features.length) { const keys = new Set(); layer.features.forEach(f => Object.keys(f.properties||{}).forEach(k => keys.add(k))); keys.forEach(k => fs.innerHTML += '<option value="' + k + '">' + k + '</option>'); } };
