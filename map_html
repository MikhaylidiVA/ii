    document.querySelectorAll('.atbl tbody tr').forEach(tr => tr.classList.remove('sel')); 
    Map.render(); 
  },
  
  showProps(f) {
    const p = f.properties || {}, g = f.geometry; const isPG = p.source === 'postgresql';
    let h = '<div class="pgrp"><div class="pgrpt">Информация</div>';
    if (isPG) h += '<div style="background:rgba(43,125,233,.08);border:1px solid rgba(43,125,233,.2);border-radius:6px;padding:8px;margin-bottom:8px;font-size:11px;color:var(--blue);"><i class="fas fa-database"></i> Источник: PostgreSQL (ID: ' + (p._pgid || '?') + ')</div>';
    h += '<div class="prow"><span class="plbl">ID</span><span class="pval">' + f.id.slice(0, 14) + '...</span></div>';
    h += '<div class="prow"><span class="plbl">Тип</span><span class="pval">' + g.type + '</span></div></div>';
    h += '<div class="pgrp"><div class="pgrpt">Геометрия</div>';
    if (g.type === 'Point') { h += '<div class="prow"><span class="plbl">Широта</span><span class="pval">' + g.coordinates[1].toFixed(6) + '</span></div>'; h += '<div class="prow"><span class="plbl">Долгота</span><span class="pval">' + g.coordinates[0].toFixed(6) + '</span></div>'; }
    else if (g.type === 'LineString') { try { const len = turf.length(turf.lineString(g.coordinates), {units:'km'}); h += '<div class="prow"><span class="plbl">Длина</span><span class="pval">' + len.toFixed(2) + ' км</span></div>'; } catch(e) {} h += '<div class="prow"><span class="plbl">Вершин</span><span class="pval">' + g.coordinates.length + '</span></div>'; }
    else if (g.type === 'Polygon' || g.type === 'MultiPolygon') { try { const area = turf.area(turf.polygon(g.type==='MultiPolygon'?g.coordinates[0][0]:g.coordinates[0])); h += '<div class="prow"><span class="plbl">Площадь</span><span class="pval">' + (area/1e6).toFixed(4) + ' км²</span></div>'; } catch(e) {} }
    h += '</div><div class="pgrp"><div class="pgrpt">Атрибуты</div>';
    for (const k in p) { if (k !== 'source') h += '<div class="prow"><span class="plbl">' + k + '</span><span class="pval">' + p[k] + '</span></div>'; }
    h += '</div><div class="pacts"><button class="btn btn-p btn-sm" onclick="App.editFeature()"><i class="fas fa-pen"></i> Изменить</button>';
    if (isPG) h += '<button class="btn btn-s btn-sm" onclick="App.updateInPG()"><i class="fas fa-database"></i> Обновить в БД</button>'; else h += '<button class="btn btn-s btn-sm" onclick="App.saveToPG()"><i class="fas fa-database"></i> В БД</button>';
    h += '<button class="btn btn-s btn-sm" onclick="App.delFeature()"><i class="fas fa-trash-can"></i> Удалить</button>';
    h += '<button class="btn btn-s btn-sm" onclick="App.zoomTo()"><i class="fas fa-magnifying-glass-plus"></i></button></div>';
    document.getElementById('pPanel').innerHTML = h;
  },
  
  updateInPG() {
    const f = Map.selectedFeature; if (!f) return; const p = f.properties || {}; const pgid = p._pgid; if (!pgid) { this.notify('Нет PG ID', 'error'); return; }
    let h = '<div style="display:flex;flex-direction:column;gap:8px;">';
    for (const k in p) { if (k === '_pgid' || k === 'source' || k === 'type' || k === 'created') continue; h += '<div><label style="font-size:10px;color:var(--gray-t);">' + k + '</label><input class="dinput" style="margin-top:3px;" id="e_' + k + '" value="' + p[k] + '"></div>'; }
    h += '</div>';
    this.showModal('Обновить в PostgreSQL', h, '<button class="btn btn-s" onclick="App.hideModal()">Отмена</button><button class="btn btn-success" onclick="App.doUpdatePG(' + pgid + ')"><i class="fas fa-database"></i> Обновить</button>');
  },
  
  async doUpdatePG(pgid) {
    const f = Map.selectedFeature; if (!f) return; const newProps = {};
    for (const k in f.properties) { if (k === '_pgid' || k === 'source') continue; const el = document.getElementById('e_' + k); newProps[k] = el ? el.value : f.properties[k]; }
    newProps._pgid = pgid; newProps.source = 'postgresql';
    await apiFetch(`/features/${pgid}`, { method: 'PUT', body: { properties: newProps } });
    f.properties = newProps; this.hideModal(); this.showProps(f); this.notify('Обновлено в PostgreSQL', 'success');
  },
  
  saveToPG() {
    const f = Map.selectedFeature; if (!f) return; const g = f.geometry;
    this.showModal('Сохранить в PostgreSQL', '<div style="display:flex;flex-direction:column;gap:8px;"><div><label style="font-size:10px;color:var(--gray-t);">Имя слоя</label><input class="dinput" style="margin-top:3px;" id="pgLayerName" value="exported_' + Date.now() + '"></div><div><label style="font-size:10px;color:var(--gray-t);">Тип геометрии</label><input class="dinput" style="margin-top:3px;" value="' + g.type + '" readonly></div></div>', '<button class="btn btn-s" onclick="App.hideModal()">Отмена</button><button class="btn btn-success" onclick="App.doSavePG()"><i class="fas fa-database"></i> Сохранить</button>');
  },
  
  async doSavePG() {
    const f = Map.selectedFeature; if (!f) return; const layerName = document.getElementById('pgLayerName').value; const g = f.geometry;
    let geoType = g.type === 'LineString' ? 'Line' : g.type === 'Polygon' || g.type === 'MultiPolygon' ? 'Polygon' : 'Point';
    let coords = g.type === 'Point' ? g.coordinates : g.type === 'LineString' ? g.coordinates : g.type === 'MultiPolygon' ? g.coordinates[0][0] : g.coordinates[0];
    showLoading('Сохранение в PostgreSQL...');
    const result = await insertFeatureToPG(layerName, geoType, coords, {...f.properties, source: 'postgresql'});
    hideLoading();
    if (result.success) { this.notify('Сохранено в PostgreSQL', 'success'); this.renderPostGISPanel(); } else { this.notify('Ошибка: ' + result.error, 'error'); }
    this.hideModal();
  },
  
  editFeature() {
    const f = Map.selectedFeature; if (!f) return; const p = f.properties || {};
    let h = '<div style="display:flex;flex-direction:column;gap:8px;">';
    for (const k in p) { if (k === '_pgid' || k === 'source' || k === 'type' || k === 'created') continue; h += '<div><label style="font-size:10px;color:var(--gray-t);">' + k + '</label><input class="dinput" style="margin-top:3px;" id="e_' + k + '" value="' + p[k] + '"></div>'; }
    h += '</div>';
    this.showModal('Редактирование', h, '<button class="btn btn-s" onclick="App.hideModal()">Отмена</button><button class="btn btn-p" onclick="App.saveEdit()">Сохранить</button>');
  },
  
  saveEdit() {
    const f = Map.selectedFeature; if (!f) return;
    for (const k in f.properties) { if (k === '_pgid' || k === 'source' || k === 'type' || k === 'created') continue; const el = document.getElementById('e_' + k); if (el) f.properties[k] = el.value; }
    GISDB.update(Map.selectedLayerId || GISDB.order[0], {}); GISDB.save(); this.hideModal(); this.showProps(f); this.renderAttrTable(); Map.render(); this.notify('Сохранено', 'success');
  },
  
  async delFeature() {
    const f = Map.selectedFeature; if (!f) return; const isPG = f.properties.source === 'postgresql'; const pgid = f.properties._pgid;
    if (isPG && pgid) { if (!confirm('Удалить из PostgreSQL?')) return; await deleteFeatureFromPG(pgid); this.notify('Удалено из PostgreSQL', 'success'); this.renderPostGISPanel(); }
    const layer = GISDB.layers[Map.selectedLayerId];
    if (layer) { layer.features = layer.features.filter(x => x.id !== f.id); GISDB.save(); }
    this.deselectAll(); this.updateUI(); Map.render();
  },
  
  zoomTo() {
    const f = Map.selectedFeature; if (!f) return; const g = f.geometry;
    if (g.type === 'Point') Map.center = {lat: g.coordinates[1], lng: g.coordinates[0]};
    else if (g.type === 'LineString' || g.type === 'Polygon' || g.type === 'MultiPolygon') {
      const coords = g.type === 'MultiPolygon' ? g.coordinates[0][0] : g.type === 'Polygon' ? g.coordinates[0] : g.coordinates;
      let minLa=90,maxLa=-90,minLo=180,maxLo=-180;
      for (const c of coords) { minLa=Math.min(minLa,c[1]);maxLa=Math.max(maxLa,c[1]);minLo=Math.min(minLo,c[0]);maxLo=Math.max(maxLo,c[0]); }
      Map.center = {lat:(minLa+maxLa)/2,lng:(minLo+maxLo)/2};
    }
    Map.zoom = 12; Map.render();
  },
  
  addPointFeature(lat, lng) { const feat = {type:'Feature',geometry:{type:'Point',coordinates:[lng,lat]},properties:{name:'Точка',type:'manual',created:new Date().toISOString()}}; this.addFeatureToLayer(feat, 'Point'); this.updateUI(); },
  
  addFeatureToLayer(feat, geoType) {
    let target = null;
    for (const id of GISDB.order) { const l = GISDB.get(id); if (l && l.type === geoType && l.name.startsWith('Пользовательские')) { target = l; break; } }
    if (!target) { GISDB.add('Пользовательские', geoType, [feat], '#2b7de9'); } else { target.features.push(feat); GISDB.save(); }
    this.notify('Объект добавлен', 'success');
  },
  
