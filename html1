// ==================== GRATICULE ====================
function addGraticule() {
  if (graticuleLayer) {
    map.removeLayer(graticuleLayer);
    graticuleLayer = null;
    showToast('Координатная сетка удалена', 'info');
    return;
  }

  graticuleLayer = L.layerGroup().addTo(map);
  const z = map.getZoom();
  const step = z > 10 ? 0.1 : z > 7 ? 0.5 : z > 4 ? 1 : 5;

  const bounds = map.getBounds();
  for (let lat = Math.floor(bounds.getSouth() / step) * step; lat <= bounds.getNorth(); lat += step) {
    L.polyline([[lat, bounds.getWest()], [lat, bounds.getEast()]], {
      color: 'rgba(255,255,255,0.2)', weight: 1, dashArray: '4,4'
    }).addTo(graticuleLayer);
  }
  for (let lon = Math.floor(bounds.getWest() / step) * step; lon <= bounds.getEast(); lon += step) {
    L.polyline([[bounds.getSouth(), lon], [bounds.getNorth(), lon]], {
      color: 'rgba(255,255,255,0.2)', weight: 1, dashArray: '4,4'
    }).addTo(graticuleLayer);
  }

  showToast('Координатная сетка добавлена', 'success');
}

