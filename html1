function measureDistance() {
  measureMode = 'distance';
  measurePoints = [];
  if (measureLayer) map.removeLayer(measureLayer);
  measureLayer = L.layerGroup().addTo(map);
  showToast('Кликайте на карте для измерения расстояния. Двойной клик — завершить.', 'info');
  logConsole('Режим измерения расстояния');

  map.once('dblclick', finishDistance);
}

function addMeasurePoint(latlng) {
  measurePoints.push(latlng);

  L.circleMarker(latlng, { radius: 4, color: '#e94560', fillColor: '#e94560', fillOpacity: 1 }).addTo(measureLayer);

  if (measurePoints.length > 1) {
    const pts = measurePoints.map(p => [p.lat, p.lng]);
    L.polyline(pts, { color: '#e94560', weight: 2, dashArray: '5,5' }).addTo(measureLayer);
  }
}

function finishDistance(e) {
  if (measurePoints.length < 2) return;

  const coords = measurePoints.map(p => [p.lng, p.lat]);
  const line = turf.lineString(coords);
  const dist = turf.length(line, { units: 'kilometers' });

  document.getElementById('measureResult').style.display = 'block';
  document.getElementById('measureResult').innerHTML =
    `<i class="fas fa-ruler"></i> Расстояние: <b>${dist.toFixed(3)} км</b> (${(dist * 1000).toFixed(1)} м)`;

  measureMode = null;
  logConsole(`Измерено расстояние: ${dist.toFixed(3)} км`);
}

function measureArea() {
  measureMode = 'area';
  measurePoints = [];
  if (measureLayer) map.removeLayer(measureLayer);
  measureLayer = L.layerGroup().addTo(map);
  showToast('Кликайте для создания полигона. Двойной клик — завершить.', 'info');

  map.once('dblclick', finishArea);
}

function finishArea(e) {
  if (measurePoints.length < 3) return;

  const coords = measurePoints.map(p => [p.lng, p.lat]);
  coords.push(coords[0]); // Close polygon
  const polygon = turf.polygon([coords]);
  const area = turf.area(polygon);

  // Draw polygon
  L.polygon(measurePoints, { color: '#00b894', fillColor: '#00b894', fillOpacity: 0.2 }).addTo(measureLayer);

  document.getElementById('measureResult').style.display = 'block';
  document.getElementById('measureResult').innerHTML =
    `<i class="fas fa-ruler-combined"></i> Площадь: <b>${area.toFixed(2)} м²</b> (${(area / 1000000).toFixed(4)} км²)`;

  measureMode = null;
  logConsole(`Измерена площадь: ${area.toFixed(2)} м²`);
}

