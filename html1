function importGeoJSONFile() { openModal('importModal'); }
function importGeoJSONUrl() { openModal('importModal'); }
function importGeoJSONText() { openModal('importModal'); }

function handleFileSelect(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    document.getElementById('importGeoJSONText').value = e.target.result;
  };
  reader.readAsText(file);
}

function processImport() {
  const name = document.getElementById('importLayerName').value || `Импорт ${Date.now()}`;
  let geojsonText = document.getElementById('importGeoJSONText').value.trim();
  const url = document.getElementById('importGeoJSONUrl').value.trim();

  const processGeoJSON = (text, layerName) => {
    try {
      const data = JSON.parse(text);
      if (!data.type) throw new Error('Неверный формат');
      createLayer(layerName, data);
      zoomToLayer(layers[layers.length - 1].id);
      showToast(`Слой "${layerName}" импортирован (${data.features?.length || 0} объектов)`, 'success');
      logConsole(`Импортирован слой: ${layerName}, объектов: ${data.features?.length || 0}`);
      saveLayers();
    } catch (err) {
      showToast('Ошибка парсинга GeoJSON: ' + err.message, 'error');
    }
  };

  if (geojsonText) {
    processGeoJSON(geojsonText, name);
  } else if (url) {
    fetch(url)
      .then(r => r.text())
      .then(text => processGeoJSON(text, name))
      .catch(err => showToast('Ошибка загрузки: ' + err.message, 'error'));
  } else {
    showToast('Укажите файл, текст или URL', 'warning');
  }

  closeModal('importModal');
  document.getElementById('importGeoJSONText').value = '';
  document.getElementById('importGeoJSONUrl').value = '';
  document.getElementById('importLayerName').value = '';
}

function exportAllGeoJSON() {
  if (layers.length === 0) return showToast('Нет слоёв для экспорта', 'warning');

  const combined = {
    type: 'FeatureCollection',
    features: [],
    properties: { exported: new Date().toISOString(), layers: layers.map(l => l.name) }
  };

  layers.forEach(l => {
    if (l.data && l.data.features) {
      l.data.features.forEach(f => {
        f.properties = f.properties || {};
        f.properties._layer = l.name;
        combined.features.push(f);
      });
