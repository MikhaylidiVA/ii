function nearestAnalysis() {
  const visibleLayers = layers.filter(l => l.data?.features?.length > 0);
  if (visibleLayers.length < 2) return showToast('Нужно минимум 2 слоя', 'warning');

  try {
    const refLayer = visibleLayers[0];
    const targetLayer = visibleLayers[1];

    const refPoints = refLayer.data.features.filter(f => f.geometry?.type === 'Point');
    const targetPoints = targetLayer.data.features.filter(f => f.geometry?.type === 'Point');

    if (refPoints.length === 0 || targetPoints.length === 0) {
      return showToast('Оба слоя должны содержать точки', 'warning');
    }

    const results = [];
    refPoints.forEach(ref => {
      let minDist = Infinity;
      let nearest = null;
      targetPoints.forEach(tgt => {
        const dist = turf.distance(ref, tgt);
        if (dist < minDist) {
          minDist = dist;
          nearest = JSON.parse(JSON.stringify(tgt));
          nearest.properties._nearestDist = minDist;
        }
      });
      if (nearest) results.push(nearest);
    });

    createLayer('Ближайшие объекты', {
      type: 'FeatureCollection',
      features: results
    }, { color: '#e17055', pointRadius: 6 });

    showToast(`Найдено ${results.length} ближайших объектов`, 'success');
  } catch (err) {
    showToast('Ошибка: ' + err.message, 'error');
  }
}

