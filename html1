function toggleGPS() {
  const btn = document.getElementById('gpsBtn');
  const info = document.getElementById('gpsInfo');

  if (gpsWatchId) {
    navigator.geolocation.clearWatch(gpsWatchId);
    gpsWatchId = null;
    btn.innerHTML = '<i class="fas fa-satellite-dish"></i> Включить GPS';
    btn.classList.remove('btn-danger');
    btn.classList.add('btn-success');
    info.style.display = 'none';
    showToast('GPS отключён', 'info');
    return;
  }

  if (!navigator.geolocation) return showToast('GPS не поддерживается', 'error');

  btn.innerHTML = '<i class="fas fa-stop"></i> Остановить GPS';
  btn.classList.remove('btn-success');
  btn.classList.add('btn-danger');
  info.style.display = 'block';

  gpsWatchId = navigator.geolocation.watchPosition(
    function(pos) {
      const lat = pos.coords.latitude;
      const lon = pos.coords.longitude;
      const acc = pos.coords.accuracy;

      document.getElementById('gpsLat').textContent = lat.toFixed(6);
      document.getElementById('gpsLon').textContent = lon.toFixed(6);
      document.getElementById('gpsAcc').textContent = acc.toFixed(1) + ' м';

      map.setView([lat, lon], map.getZoom());
      L.circleMarker([lat, lon], {
        radius: 8, color: '#e94560', fillColor: '#e94560', fillOpacity: 1
      }).addTo(drawnItems);
    },
    function(err) {
      showToast('Ошибка GPS: ' + err.message, 'error');
    },
    { enableHighAccuracy: true, maximumAge: 1000 }
  );

  showToast('GPS включён', 'success');
}

