<script>
// ============================================================
// GEOWEB PRO — Full-Featured GeoGIS Platform
// ============================================================

// ==================== AUTH SYSTEM ====================
const DB = {
  getUsers() {
    return JSON.parse(localStorage.getItem('geoweb_users') || '[]');
  },
  saveUsers(users) {
    localStorage.setItem('geoweb_users', JSON.stringify(users));
  },
  getCurrentUser() {
    return JSON.parse(sessionStorage.getItem('geoweb_current') || localStorage.getItem('geoweb_current') || 'null');
  },
  saveCurrentUser(user) {
    if (user) {
      const storage = document.getElementById('rememberMe')?.checked ? localStorage : sessionStorage;
      storage.setItem('geoweb_current', JSON.stringify(user));
    }
  },
  clearCurrentUser() {
    localStorage.removeItem('geoweb_current');
    sessionStorage.removeItem('geoweb_current');
  }
};

function switchAuthTab(tab) {
  document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.auth-form').forEach(f => f.classList.remove('active'));
  if (tab === 'login') {
    document.querySelectorAll('.auth-tab')[0].classList.add('active');
    document.getElementById('loginForm').classList.add('active');
  } else {
    document.querySelectorAll('.auth-tab')[1].classList.add('active');
    document.getElementById('registerForm').classList.add('active');
  }
  document.getElementById('authError').style.display = 'none';
}

function showAuthError(msg) {
  const el = document.getElementById('authError');
  el.textContent = msg;
  el.style.display = 'block';
}

function handleRegister(e) {
  e.preventDefault();
  const name = document.getElementById('regName').value.trim();
  const email = document.getElementById('regEmail').value.trim().toLowerCase();
  const password = document.getElementById('regPassword').value;
  const password2 = document.getElementById('regPassword2').value;
  const role = document.getElementById('regRole').value;

  if (password !== password2) return showAuthError('Пароли не совпадают');
  if (password.length < 6) return showAuthError('Пароль минимум 6 символов');

  const users = DB.getUsers();
  if (users.find(u => u.email === email)) return showAuthError('Email уже зарегистрирован');

  const user = {
    id: Date.now().toString(),
    name,
    email,
    password: btoa(password), // Simple encoding (not secure, demo only)
    role,
    created: new Date().toISOString(),
    projects: [],
    settings: { theme: 'dark' }
  };

  users.push(user);
  DB.saveUsers(users);
  DB.saveCurrentUser({ id: user.id, name: user.name, email: user.email, role: user.role });

  showAuthSuccess('Аккаунт создан! Входим...');
  setTimeout(() => enterApp(user), 1000);
}

function showAuthSuccess(msg) {
  const el = document.getElementById('authError');
  el.textContent = msg;
  el.style.display = 'block';
  el.style.borderColor = 'var(--success)';
  el.style.background = 'rgba(0,184,148,0.2)';
  el.style.color = 'var(--success)';
}

function handleLogin(e) {
  e.preventDefault();
  const email = document.getElementById('loginEmail').value.trim().toLowerCase();
  const password = document.getElementById('loginPassword').value;

  const users = DB.getUsers();
  const user = users.find(u => u.email === email && atob(u.password) === password);

  if (!user) return showAuthError('Неверный email или пароль');

  DB.saveCurrentUser({ id: user.id, name: user.name, email: user.email, role: user.role });
  enterApp(user);
}

function enterApp(user) {
  document.getElementById('authScreen').style.display = 'none';
  document.getElementById('appScreen').style.display = 'block';
  document.getElementById('userName').textContent = user.name;
  document.getElementById('userAvatar').textContent = user.name.charAt(0).toUpperCase();

  logConsole(`Пользователь ${user.name} (${user.role}) вошёл в систему`);
  initMap();
  initApp();
}

function logout() {
  DB.clearCurrentUser();
  location.reload();
}

// Check session on load
(function checkSession() {
  const user = DB.getCurrentUser();
  if (user) {
    const users = DB.getUsers();
    const fullUser = users.find(u => u.id === user.id);
    if (fullUser) {
      enterApp(fullUser);
    }
  }
})();

// ==================== MAP INITIALIZATION ====================
let map, drawControl, drawnItems, measureControl;
let layers = [];
let currentLayerId = null;
let activeTool = null;
let measureMode = null;
let measurePoints = [];
let measureLayer = null;
let gpsWatchId = null;
let graticuleLayer = null;
let scaleBarControl = null;
let northArrowControl = null;
let bookmarks = [];

function initMap() {
  map = L.map('map', {
    center: [55.7558, 37.6173],
    zoom: 5,
    zoomControl: false,
    attributionControl: true
  });

  L.control.zoom({ position: 'bottomright' }).addTo(map);

  // Base layers
  const osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors',
    maxZoom: 19
  });

  const satelliteLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: '© Esri',
    maxZoom: 18
  });

  const topoLayer = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenTopoMap',
    maxZoom: 17
  });

  const darkLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© CartoDB',
    maxZoom: 19
  });

  const baseMaps = {
    'OSM': osmLayer,
    'Спутник': satelliteLayer,
    'Топо': topoLayer,
    'Тёмная': darkLayer
  };

  osmLayer.addTo(map);
  L.control.layers(baseMaps, null, { position: 'topright' }).addTo(map);

  // Draw control
  drawnItems = new L.FeatureGroup();
  map.addLayer(drawnItems);

  drawControl = new L.Control.Draw({
    position: 'topright',
    draw: {
      polygon: { shapeOptions: { color: '#e94560' } },
      polyline: { shapeOptions: { color: '#e94560' } },
      circle: { shapeOptions: { color: '#e94560' } },
      rectangle: { shapeOptions: { color: '#e94560' } },
      marker: true,
      circlemarker: false
    },
    edit: {
      featureGroup: drawnItems,
      remove: true
    }
  });
  map.addControl(drawControl);

  // Draw events
  map.on(L.Draw.Event.CREATED, function(e) {
    const layer = e.layer;
    drawnItems.addLayer(layer);
    addToCurrentLayer(layer);
    logConsole(`Создан объект: ${e.layerType}`);
  });

  map.on(L.Draw.Event.EDITED, function() {
    syncDrawnToLayers();
    logConsole('Объекты отредактированы');
  });

  map.on(L.Draw.Event.DELETED, function() {
    syncDrawnToLayers();
    logConsole('Объекты удалены');
  });

  // Mouse move - coordinates
  map.on('mousemove', function(e) {
    document.getElementById('coordDisplay').textContent =
      `Lat: ${e.latlng.lat.toFixed(6)} | Lon: ${e.latlng.lng.toFixed(6)}`;
  });

  map.on('zoomend', updateScaleInfo);
  updateScaleInfo();

  // Scale bar
  L.control.scale({ position: 'bottomleft', imperial: false }).addTo(map);

  // Click for feature info
  map.on('click', function(e) {
    if (measureMode === 'distance' || measureMode === 'area') {
      addMeasurePoint(e.latlng);
    }
  });
}

function updateScaleInfo() {
  const z = map.getZoom();
  const scales = {
    1: '1:500M', 2: '1:250M', 3: '1:150M', 4: '1:70M', 5: '1:35M',
    6: '1:20M', 7: '1:10M', 8: '1:4M', 9: '1:2M', 10: '1:1M',
    11: '1:500K', 12: '1:250K', 13: '1:100K', 14: '1:50K', 15: '1:25K',
    16: '1:12K', 17: '1:6K', 18: '1:3K', 19: '1:1K'
  };
  document.getElementById('scaleInfo').textContent = `Zoom: ${z} | Scale: ~${scales[z] || '—'}`;
}

// ==================== APP INITIALIZATION ====================
function initApp() {
  // Add default empty layer
  addEmptyLayer('Слой 1');

  // Load saved layers
  loadSavedLayers();
  loadBookmarks();
  updateLayerList();
  updateLayerSelects();
}

// ==================== LAYER MANAGEMENT ====================
let layerCounter = 0;

function createLayer(name, geojsonData, options = {}) {
  const id = 'layer_' + (++layerCounter);
  const defaultStyle = {
    color: options.color || randomColor(),
    weight: options.weight || 2,
    fillColor: options.fillColor || options.color || randomColor(),
    fillOpacity: options.fillOpacity || 0.3,
    dashArray: options.dashArray || '',
    pointRadius: options.pointRadius || 6
  };

  const layer = {
    id,
    name: name || `Слой ${layerCounter}`,
    data: geojsonData || { type: 'FeatureCollection', features: [] },
    style: defaultStyle,
    visible: true,
    opacity: 1,
    leafletLayer: null,
    created: new Date().toISOString()
  };

  layers.push(layer);
  renderLayer(layer);
  updateLayerList();
  updateLayerSelects();
  return layer;
}

function addEmptyLayer(name) {
  const layer = createLayer(name || `Слой ${layerCounter + 1}`, {
    type: 'FeatureCollection',
    features: []
  });
  showToast(`Слой "${layer.name}" создан`, 'success');
  return layer;
}

function renderLayer(layer) {
  if (layer.leafletLayer) {
    map.removeLayer(layer.leafletLayer);
  }

  if (!layer.data || !layer.data.features || layer.data.features.length === 0) return;

  const style = getStyleFunction(layer);

  layer.leafletLayer = L.geoJSON(layer.data, {
    style: style,
    pointToLayer: function(feature, latlng) {
      return L.circleMarker(latlng, {
        radius: layer.style.pointRadius || 6,
        fillColor: layer.style.fillColor || layer.style.color,
        color: layer.style.color,
        weight: layer.style.weight || 2,
        fillOpacity: layer.style.fillOpacity || 0.3,
        dashArray: layer.style.dashArray || null
      });
    },
    onEachFeature: function(feature, layer) {
      layer.on('click', function(e) {
        showFeatureInfo(feature, e.latlng);
      });
      layer.bindPopup(function(l) {
        const props = l.feature?.properties || {};
        let html = '<div class="feature-popup"><table>';
        for (const [key, val] of Object.entries(props)) {
          html += `<tr><td>${key}</td><td>${val}</td></tr>`;
        }
        html += '</table></div>';
        return html || 'Нет атрибутов';
      });
    }
  });

  if (layer.visible) {
    layer.leafletLayer.addTo(map);
  }
}

function getStyleFunction(layer) {
  return function(feature) {
    return {
      color: layer.style.color,
      weight: layer.style.weight,
      fillColor: layer.style.fillColor,
      fillOpacity: layer.style.fillOpacity,
      dashArray: layer.style.dashArray || null
    };
  };
}

function addToCurrentLayer(leafletLayer) {
  const layer = layers.find(l => l.id === currentLayerId);
  if (!layer) return;

  const geojson = leafletLayer.toGeoJSON();
  layer.data.features.push(geojson);
  renderLayer(layer);
  updateLayerList();
  showToast('Объект добавлен в слой', 'success');
}

function syncDrawnToLayers() {
  // Sync drawn items back to layers
  drawnItems.eachLayer(function(layer) {
    // This is handled by renderLayer
  });
}

function removeLayer(layerId) {
  const idx = layers.findIndex(l => l.id === (layerId || currentLayerId));
  if (idx === -1) return;

  const layer = layers[idx];
  if (layer.leafletLayer) map.removeLayer(layer.leafletLayer);
  layers.splice(idx, 1);

  if (currentLayerId === layer.id) {
    currentLayerId = layers.length > 0 ? layers[0].id : null;
  }

  updateLayerList();
  updateLayerSelects();
  showToast(`Слой "${layer.name}" удалён`, 'warning');
  logConsole(`Слой удалён: ${layer.name}`);
}

function toggleLayerVisibility(layerId) {
  const layer = layers.find(l => l.id === layerId);
  if (!layer) return;

  layer.visible = !layer.visible;
  if (layer.visible && layer.leafletLayer) {
    map.addLayer(layer.leafletLayer);
  } else if (layer.leafletLayer) {
    map.removeLayer(layer.leafletLayer);
  }

  updateLayerList();
}

function setLayerOpacity(layerId, value) {
  const layer = layers.find(l => l.id === layerId);
  if (!layer) return;
  layer.opacity = value;
  if (layer.leafletLayer) {
    layer.leafletLayer.eachLayer(function(l) {
      if (l.setStyle) {
        l.setStyle({ fillOpacity: value * (layer.style.fillOpacity || 0.3) });
      }
      if (l.setOpacity) l.setOpacity(value);
    });
  }
}

function duplicateLayer() {
  const layer = layers.find(l => l.id === currentLayerId);
  if (!layer) return showToast('Выберите слой', 'warning');

  const copy = JSON.parse(JSON.stringify(layer.data));
  createLayer(layer.name + ' (копия)', copy, { ...layer.style });
  showToast(`Слой "${layer.name}" дублирован`, 'success');
}

function mergeLayers() {
  if (layers.length < 2) return showToast('Нужно минимум 2 слоя', 'warning');

  const merged = { type: 'FeatureCollection', features: [] };
  layers.forEach(l => {
    if (l.data && l.data.features) {
      merged.features = merged.features.concat(l.data.features);
    }
  });

  createLayer('Объединённый слой', merged);
  showToast('Слои объединены', 'success');
}

