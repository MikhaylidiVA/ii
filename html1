function highlightFeature(index, layerId) {
  const layer = layers.find(l => l.id === layerId);
  if (!layer) return;

  const feature = layer.data.features[index];
  if (!feature) return;

  // Highlight on map
  if (layer.leafletLayer) {
    layer.leafletLayer.eachLayer(function(l, i) {
      if (i === index) {
        if (l.setStyle) l.setStyle({ weight: 4, color: '#e94560' });
        l.openPopup();
      } else {
        if (l.setStyle) l.setStyle({ weight: layer.style.weight || 2, color: layer.style.color });
      }
    });
  }

  // Zoom to feature
  if (layer.leafletLayer) {
    const fl = layer.leafletLayer.getLayers()[index];
    if (fl) {
      if (fl.getBounds) map.fitBounds(fl.getBounds().pad(0.1));
      else if (fl.getLatLng) map.setView(fl.getLatLng(), 14);
    }
  }
}

