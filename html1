// ==================== STATISTICS ====================
function layerStatistics() {
  const layer = layers.find(l => l.id === currentLayerId);
  if (!layer) return showToast('Выберите слой', 'warning');

  const fc = layer.data;
  const features = fc.features;
  const total = features.length;

  const types = {};
  features.forEach(f => {
    const t = f.geometry?.type || 'Unknown';
    types[t] = (types[t] || 0) + 1;
  });

  const bbox = turf.bbox(fc);
  const area = turf.area(fc);
  const center = turf.center(fc);

  // Numeric field statistics
  const numericFields = {};
  features.forEach(f => {
    if (f.properties) {
      Object.entries(f.properties).forEach(([key, val]) => {
        if (typeof val === 'number') {
          if (!numericFields[key]) numericFields[key] = [];
          numericFields[key].push(val);
        }
      });
    }
  });

  let statsHTML = `
    <div style="margin-bottom:15px;">
      <h4 style="color:var(--accent);margin-bottom:8px;">Общая информация</h4>
      <table style="width:100%;font-size:13px;">
        <tr><td style="color:var(--text-dim);padding:4px 8px;">Объектов:</td><td><b>${total}</b></td></tr>
        <tr><td style="color:var(--text-dim);padding:4px 8px;">Типы геометрий:</td><td>${Object.entries(types).map(([k,v]) => `${k}: ${v}`).join(', ')}</td></tr>
        <tr><td style="color:var(--text-dim);padding:4px 8px;">Площадь:</td><td>${(area / 1000000).toFixed(2)} км²</td></tr>
        <tr><td style="color:var(--text-dim);padding:4px 8px;">Центр:</td><td>${center.geometry.coordinates[1].toFixed(4)}, ${center.geometry.coordinates[0].toFixed(4)}</td></tr>
        <tr><td style="color:var(--text-dim);padding:4px 8px;">BBOX:</td><td>${bbox.map(v => v.toFixed(4)).join(', ')}</td></tr>
      </table>
    </div>
  `;

  if (Object.keys(numericFields).length > 0) {
    statsHTML += '<h4 style="color:var(--accent);margin-bottom:8px;">Числовые поля</h4>';
    Object.entries(numericFields).forEach(([field, values]) => {
      const min = Math.min(...values);
      const max = Math.max(...values);
      const sum = values.reduce((a, b) => a + b, 0);
      const avg = sum / values.length;
      const stdDev = Math.sqrt(values.reduce((s, v) => s + (v - avg) ** 2, 0) / values.length);

      statsHTML += `
        <div style="background:var(--bg-dark);border-radius:var(--radius);padding:10px;margin-bottom:8px;">
          <b>${field}</b><br>
          <span style="font-size:12px;color:var(--text-dim);">
            Min: ${min.toFixed(2)} | Max: ${max.toFixed(2)} | Avg: ${avg.toFixed(2)} | Σ: ${sum.toFixed(2)} | σ: ${stdDev.toFixed(2)} | n: ${values.length}
          </span>
        </div>
      `;
    });
  }

  document.getElementById('statsModalBody').innerHTML = statsHTML;
  openModal('statsModal');
}

