function applyChoropleth() {
  const layer = layers.find(l => l.id === currentLayerId);
  if (!layer) return showToast('Выберите слой', 'warning');

  const field = document.getElementById('choroplethField').value;
  const scheme = document.getElementById('choroplethScheme').value;
  const classes = parseInt(document.getElementById('choroplethClasses').value);

  if (!field) return showToast('Выберите поле', 'warning');

  const values = layer.data.features
    .map(f => f.properties?.[field])
    .filter(v => v !== undefined && v !== null)
    .map(Number)
    .filter(v => !isNaN(v));

  if (values.length === 0) return showToast('Нет числовых данных в поле', 'warning');

  const min = Math.min(...values);
  const max = Math.max(...values);
  const step = (max - min) / classes;

  const colorSchemes = {
    reds: ['#fee5d9', '#fcbba1', '#fc9272', '#fb6a4a', '#ef3b2c', '#cb181d', '#99000d'],
    blues: ['#edf8fb', '#ccece6', '#99d8c9', '#66c2a4', '#41ae76', '#238b45', '#005824'],
    greens: ['#f7fcf5', '#e5f5e0', '#c7e9c0', '#a1d99b', '#74c476', '#41ab5d', '#238443'],
    purples: ['#fcfbfd', '#efedf5', '#dadaeb', '#bcbddc', '#9e9ac8', '#807dba', '#6a51a3'],
    oranges: ['#fff5eb', '#fee6ce', '#fdd0a2', '#fdae6b', '#fd8d3c', '#f16913', '#d94801']
  };

  const colors = colorSchemes[scheme] || colorSchemes.reds;

  layer.data.features.forEach(f => {
    const val = f.properties?.[field];
    if (val !== undefined) {
      const num = Number(val);
      if (!isNaN(num)) {
        const idx = Math.min(Math.floor((num - min) / step), colors.length - 1);
        f.properties._choroplethColor = colors[Math.max(0, idx)];
      }
    }
  });

  // Re-render with choropleth colors
  if (layer.leafletLayer) map.removeLayer(layer.leafletLayer);

  layer.leafletLayer = L.geoJSON(layer.data, {
    style: function(feature) {
      return {
        color: feature.properties._choroplethColor || layer.style.color,
        weight: layer.style.weight,
        fillColor: feature.properties._choroplethColor || layer.style.fillColor,
        fillOpacity: layer.style.fillOpacity,
        dashArray: layer.style.dashArray
      };
    },
    pointToLayer: function(feature, latlng) {
      return L.circleMarker(latlng, {
        radius: layer.style.pointRadius,
        fillColor: feature.properties._choroplethColor || layer.style.fillColor,
        color: feature.properties._choroplethColor || layer.style.color,
        weight: layer.style.weight,
        fillOpacity: layer.style.fillOpacity
      });
    }
  });

  layer.leafletLayer.addTo(map);
  showToast(`Хороплет применён по полю "${field}"`, 'success');
}

function filterLayer() {
  const layer = layers.find(l => l.id === currentLayerId);
  if (!layer) return showToast('Выберите слой', 'warning');

