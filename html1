}

function applyFilter() {
  const layer = layers.find(l => l.id === currentLayerId);
  if (!layer) return;

  const field = document.getElementById('filterField').value;
  const operator = document.getElementById('filterOperator').value;
  const value = document.getElementById('filterValue').value;

  if (!field) return showToast('Выберите поле', 'warning');

  const allFeatures = layer._originalFeatures || layer.data.features;
  if (!layer._originalFeatures) layer._originalFeatures = JSON.parse(JSON.stringify(layer.data.features));

  const filtered = allFeatures.filter(f => {
    const fv = f.properties?.[field];
    if (fv === undefined) return false;

    switch (operator) {
      case '==': return String(fv) === value;
      case '!=': return String(fv) !== value;
      case '>': return Number(fv) > Number(value);
      case '<': return Number(fv) < Number(value);
      case '>=': return Number(fv) >= Number(value);
      case '<=': return Number(fv) <= Number(value);
      case 'contains': return String(fv).toLowerCase().includes(value.toLowerCase());
      default: return true;
    }
  });

  layer.data.features = filtered;
  renderLayer(layer);
  updateLayerList();
  closeModal('filterModal');
  showToast(`Фильтр применён: ${filtered.length} объектов`, 'success');
}

function clearFilter() {
  const layer = layers.find(l => l.id === currentLayerId);
  if (!layer) return;

  if (layer._originalFeatures) {
    layer.data.features = layer._originalFeatures;
    delete layer._originalFeatures;
    renderLayer(layer);
    updateLayerList();
  }

  closeModal('filterModal');
  showToast('Фильтр сброшен', 'info');
}

