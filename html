}

function applyStyle() {
  const layerId = document.getElementById('style-layer').value;
  if (!layerId) return toast('Выберите слой', 'error');
  
  const style = {
    fillColor: document.getElementById('st-fill').value,
    color: document.getElementById('st-stroke').value,
    fillOpacity: parseFloat(document.getElementById('st-opacity').value),
    weight: parseInt(document.getElementById('st-weight').value),
    radius: parseInt(document.getElementById('st-radius').value)
  };
  
  state.layers[layerId].style = style;
  state.layers[layerId].layer.setStyle(style);
  
  // Обновить маркеры
  state.layers[layerId].layer.eachLayer(l => {
    if (l.setRadius) l.setRadius(style.radius);
  });
  
  toast('Стиль применён', 'success');
}

function randomStyle() {
  const r = () => Math.floor(Math.random() * 256);
  const color = `#${r().toString(16).padStart(2,'0')}${r().toString(16).padStart(2,'0')}${r().toString(16).padStart(2,'0')}`;
  document.getElementById('st-fill').value = color;
  document.getElementById('st-stroke').value = color;
}

function clusterPoints() {
  const layerId = document.getElementById('cl-layer').value;
  const radius = parseFloat(document.getElementById('cl-radius').value);
  if (!layerId || !radius) return toast('Заполните все поля', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  const clusters = turf.clustersDbscan(geojson, radius, {units: 'kilometers', minPoints: 2});
  
  // Раскрасить по кластерам
  const colors = ['#ff5555','#50fa7b','#8be9fd','#f1fa8c','#ff79c6','#bd93f9','#ffb86c'];
  clusters.features.forEach((f, i) => {
    f.properties.cluster_color = colors[f.properties.cluster % colors.length] || '#6272a4';
  });
  
  addLayer(`${state.layers[layerId].name}_кластеры`, clusters, {
    radius: 6
  });
  
  // Применить цвета
  const newLayerId = Object.keys(state.layers).pop();
  state.layers[newLayerId].layer.eachLayer(l => {
    const color = l.feature.properties.cluster_color;
    l.setStyle({fillColor: color, color: color});
  });
}

function createChoropleth() {
  const layerId = document.getElementById('choro-layer').value;
  const field = document.getElementById('choro-field').value;
  if (!layerId || !field) return toast('Заполните все поля', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  const values = geojson.features
    .map(f => parseFloat(f.properties?.[field]))
    .filter(v => !isNaN(v));
  
  if (values.length === 0) return toast('Нет числовых значений', 'error');
  
  const min = Math.min(...values);
  const max = Math.max(...values);
  
  const getColor = v => {
    const ratio = (v - min) / (max - min || 1);
    const r = Math.floor(255 * ratio);
    const b = Math.floor(255 * (1 - ratio));
    return `rgb(${r},50,${b})`;
  };
  
  geojson.features.forEach(f => {
    const val = parseFloat(f.properties?.[field]);
    f.properties._choro_color = isNaN(val) ? '#666' : getColor(val);
  });
  
  addLayer(`${state.layers[layerId].name}_хороплет_${field}`, geojson);
  
  const newLayerId = Object.keys(state.layers).pop();
  state.layers[newLayerId].layer.eachLayer(l => {
    const color = l.feature.properties._choro_color;
    l.setStyle({fillColor: color, color: '#fff', fillOpacity: 0.7});
  });
}

