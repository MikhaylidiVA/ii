function updateFromJSON() {
  const layerId = document.getElementById('json-layer').value;
  if (!layerId) return toast('Выберите слой', 'error');
  
  try {
    const geojson = JSON.parse(document.getElementById('json-editor').value);
    state.layers[layerId].layer.clearLayers();
    state.layers[layerId].layer.addData(geojson);
    toast('GeoJSON обновлён', 'success');
  } catch (err) {
    toast('Ошибка JSON: ' + err.message, 'error');
  }
}

function showStats() {
  const layerId = document.getElementById('stat-layer').value;
  if (!layerId) return toast('Выберите слой', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  const stats = {
    features: geojson.features.length,
    points: 0,
    lines: 0,
    polygons: 0,
    totalArea: 0,
    totalLength: 0
  };
  
  geojson.features.forEach(f => {
    const type = f.geometry.type;
    if (type.includes('Point')) stats.points++;
    else if (type.includes('LineString')) {
      stats.lines++;
      stats.totalLength += turf.length(f, {units: 'kilometers'});
    }
    else if (type.includes('Polygon')) {
      stats.polygons++;
      stats.totalArea += turf.area(f) / 1e6;
    }
  });
  
  document.getElementById('stats-out').innerHTML = `
    <b>Объектов:</b> ${stats.features}<br>
    <b>Точек:</b> ${stats.points}<br>
    <b>Линий:</b> ${stats.lines} (${stats.totalLength.toFixed(2)} км)<br>
    <b>Полигонов:</b> ${stats.polygons} (${stats.totalArea.toFixed(2)} км²)
  `;
}

// ============ AUTH ============
function showAuth() {
  document.getElementById('auth-modal').style.display = 'flex';
}

function hideAuth() {
  document.getElementById('auth-modal').style.display = 'none';
}

function register() {
  const username = document.getElementById('auth-user').value.trim();
  const password = document.getElementById('auth-pass').value;
  
  if (!username || !password) return toast('Заполните все поля', 'error');
  
  const users = JSON.parse(localStorage.getItem('qgis_users') || '{}');
  if (users[username]) return toast('Пользователь уже существует', 'error');
  
  users[username] = {password: btoa(password), created: Date.now()};
  localStorage.setItem('qgis_users', JSON.stringify(users));
  toast('Регистрация успешна! Теперь войдите.', 'success');
}

function login() {
  const username = document.getElementById('auth-user').value.trim();
  const password = document.getElementById('auth-pass').value;
  
  const users = JSON.parse(localStorage.getItem('qgis_users') || '{}');
  
  // Демо-аккаунт
  if (username === 'admin' && password === 'admin') {
    state.user = {username: 'admin', role: 'admin'};
  } else if (users[username] && users[username].password === btoa(password)) {
    state.user = {username, role: 'user'};
  } else {
    return toast('Неверный логин или пароль', 'error');
  }
  
  document.getElementById('user-info').textContent = `👤 ${state.user.username}`;
  document.getElementById('auth-btn').textContent = '🚪 Выйти';
  document.getElementById('auth-btn').onclick = logout;
  hideAuth();
  toast(`Добро пожаловать, ${state.user.username}!`, 'success');
}

function logout() {
  state.user = null;
  document.getElementById('user-info').textContent = 'Гость';
  document.getElementById('auth-btn').textContent = '🔐 Войти';
  document.getElementById('auth-btn').onclick = showAuth;
  toast('Вы вышли из системы', 'info');
}

// ============ UI HELPERS ============
function switchTab(name, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tabs button').forEach(b => b.classList.remove('active'));
  document.getElementById(`tab-${name}`).classList.add('active');
  btn.classList.add('active');
}

function showModal(title, content) {
  const bg = document.createElement('div');
  bg.className = 'modal-bg';
  bg.innerHTML = `<div class="modal"><h2>${title}</h2>${content}<button onclick="this.closest('.modal-bg').remove()" style="margin-top:15px">Закрыть</button></div>`;
  bg.onclick = e => {if (e.target === bg) bg.remove()};
  document.body.appendChild(bg);
}

function toast(msg, type = 'info') {
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = msg;
  document.getElementById('toast').appendChild(t);
  setTimeout(() => t.remove(), 4000);
}

function fitAll() {
  const bounds = L.featureGroup(Object.values(state.layers).map(l => l.layer)).getBounds();
  if (bounds.isValid()) map.fitBounds(bounds, {padding: [50, 50]});
}

function setStatus(msg) {
  document.getElementById('status-msg').textContent = msg;
}

