<script>
// ============ STATE ============
const state = {
  layers: {},
  activeLayerId: null,
  user: null,
  layerCounter: 0
};

// ============ INIT MAP ============
const map = L.map('map', {
  center: [55.75, 37.62],
  zoom: 5,
  zoomControl: true
});

// Base layers
const baseLayers = {
  osm: L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap',
    maxZoom: 19
  }),
  sat: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: '© Esri',
    maxZoom: 19
  }),
  topo: L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenTopoMap',
    maxZoom: 17
  }),
  dark: L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© CartoDB',
    maxZoom: 19
  }),
  light: L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '© CartoDB',
    maxZoom: 19
  }),
  terrain: L.tileLayer('https://stamen-tiles-{s}.a.ssl.fastly.net/terrain/{z}/{x}/{y}.jpg', {
    attribution: '© Stamen',
    maxZoom: 18
  })
};

let currentBase = baseLayers.osm;
currentBase.addTo(map);

function changeBase(name) {
  map.removeLayer(currentBase);
  currentBase = baseLayers[name];
  currentBase.addTo(map);
  currentBase.bringToBack();
  toast('Базовый слой изменён', 'success');
}

// ============ GEOMAN (EDITING) ============
map.pm.addControls({
  position: 'topleft',
  drawCircle: false,
  drawCircleMarker: true,
  drawMarker: true,
  drawPolyline: true,
  drawRectangle: true,
  drawPolygon: true,
  drawText: true,
  editMode: true,
  dragMode: true,
  cutPolygon: true,
  removalMode: true,
  rotateMode: true
});

map.pm.setGlobalOptions({
  pmIgnore: false,
  snapDistance: 15
});

// ============ COORDS & ZOOM ============
map.on('mousemove', e => {
  document.getElementById('coords').textContent = 
    `${e.latlng.lat.toFixed(5)}, ${e.latlng.lng.toFixed(5)}`;
});

map.on('zoomend', () => {
  document.getElementById('zoom').textContent = map.getZoom();
});

// ============ LAYER MANAGEMENT ============
function addLayer(name, geojson, style = {}) {
  const id = `layer_${++state.layerCounter}`;
  const defaultStyle = {
    color: '#8be9fd',
    fillColor: '#8be9fd',
    fillOpacity: 0.4,
    weight: 2,
    radius: 6,
    ...style
  };

  const layer = L.geoJSON(geojson || {type:'FeatureCollection',features:[]}, {
    style: defaultStyle,
    pointToLayer: (feature, latlng) => {
      return L.circleMarker(latlng, {
        radius: defaultStyle.radius,
        fillColor: defaultStyle.fillColor,
        color: defaultStyle.color,
        weight: defaultStyle.weight,
        opacity: 1,
        fillOpacity: defaultStyle.fillOpacity
      });
    },
    onEachFeature: (feature, layer) => {
      if (feature.properties) {
        const props = Object.entries(feature.properties)
          .map(([k,v]) => `<b>${k}:</b> ${v}`).join('<br>');
        layer.bindPopup(props || 'Нет атрибутов');
      }
    }
  }).addTo(map);

  state.layers[id] = {
    id,
    name: name || `Слой ${state.layerCounter}`,
    layer,
    style: defaultStyle,
    visible: true,
    filter: null
  };

  state.activeLayerId = id;
  refreshLayerList();
  refreshSelects();
  toast(`Слой "${name}" добавлен`, 'success');
  return id;
}

function refreshLayerList() {
  const list = document.getElementById('layer-list');
  list.innerHTML = '';
  document.getElementById('layer-count').textContent = Object.keys(state.layers).length;

  Object.values(state.layers).forEach(l => {
    const div = document.createElement('div');
    div.className = 'layer-item' + (l.id === state.activeLayerId ? ' active' : '');
    div.innerHTML = `
      <input type="checkbox" ${l.visible ? 'checked' : ''} onchange="toggleLayer('${l.id}')">
      <span class="lname" onclick="setActive('${l.id}')">${l.name}</span>
      <div class="actions">
        <button onclick="renameLayer('${l.id}')" title="Переименовать">✏️</button>
        <button onclick="zoomToLayer('${l.id}')" title="Приблизить">🔍</button>
        <button onclick="deleteLayer('${l.id}')" title="Удалить">🗑️</button>
      </div>
    `;
    list.appendChild(div);
  });
}

function toggleLayer(id) {
  const l = state.layers[id];
  l.visible = !l.visible;
  if (l.visible) {
    map.addLayer(l.layer);
  } else {
    map.removeLayer(l.layer);
  }
}

function setActive(id) {
  state.activeLayerId = id;
  refreshLayerList();
}

function renameLayer(id) {
  const newName = prompt('Новое имя:', state.layers[id].name);
  if (newName) {
    state.layers[id].name = newName;
    refreshLayerList();
    refreshSelects();
  }
}

function zoomToLayer(id) {
  const bounds = state.layers[id].layer.getBounds();
  if (bounds.isValid()) {
    map.fitBounds(bounds, {padding: [50, 50]});
  }
}

function deleteLayer(id) {
  if (!confirm(`Удалить слой "${state.layers[id].name}"?`)) return;
  map.removeLayer(state.layers[id].layer);
  delete state.layers[id];
  refreshLayerList();
  refreshSelects();
  toast('Слой удалён', 'success');
}

function addEmptyLayer() {
  const name = prompt('Имя нового слоя:', `Новый слой ${state.layerCounter + 1}`);
  if (name) addLayer(name, null);
}

function refreshSelects() {
  const opts = Object.values(state.layers)
    .map(l => `<option value="${l.id}">${l.name}</option>`).join('');
  
  ['buf-layer','cent-layer','conv-layer','measure-layer','int-a','int-b',
   'uni-a','uni-b','filt-layer','grid-layer','style-layer','cl-layer',
   'choro-layer','attr-layer','json-layer','stat-layer'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = opts;
  });
}

// ============ FILE LOADING ============
function loadFiles(e) {
  Array.from(e.target.files).forEach(file => {
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const geojson = JSON.parse(ev.target.result);
        addLayer(file.name.replace(/\.[^.]+$/, ''), geojson);
      } catch (err) {
        toast('Ошибка загрузки: ' + err.message, 'error');
      }
    };
    reader.readAsText(file);
  });
  e.target.value = '';
}

function promptUrlLoad() {
  const url = prompt('URL GeoJSON файла:');
  if (!url) return;
  toast('Загрузка...', 'info');
  fetch(url)
    .then(r => r.json())
    .then(data => {
      addLayer(url.split('/').pop() || 'URL Layer', data);
    })
    .catch(err => toast('Ошибка: ' + err.message, 'error'));
}

// ============ EXPORT ============
function exportAll() {
  Object.values(state.layers).forEach(l => {
    const geojson = l.layer.toGeoJSON();
    const blob = new Blob([JSON.stringify(geojson, null, 2)], {type: 'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${l.name}.geojson`;
    a.click();
    URL.revokeObjectURL(url);
  });
  toast('Экспорт завершён', 'success');
}

// ============ PROJECT SAVE/LOAD ============
function saveProject() {
  if (!state.user) {
    toast('Войдите для сохранения проектов', 'error');
    return;
  }
  const project = {
    layers: Object.values(state.layers).map(l => ({
      name: l.name,
      geojson: l.layer.toGeoJSON(),
      style: l.style
    }))
  };
  const key = `qgis_project_${state.user.username}_${Date.now()}`;
  localStorage.setItem(key, JSON.stringify(project));
  toast('Проект сохранён', 'success');
}

function loadProject() {
  if (!state.user) {
    toast('Войдите для загрузки проектов', 'error');
    return;
  }
  const keys = Object.keys(localStorage).filter(k => k.startsWith(`qgis_project_${state.user.username}_`));
  if (keys.length === 0) {
    toast('Нет сохранённых проектов', 'info');
    return;
  }
  const key = prompt('Выберите проект:\n' + keys.map((k,i) => `${i+1}. ${k}`).join('\n'));
  if (!key) return;
  const idx = parseInt(key) - 1;
  if (idx < 0 || idx >= keys.length) return;
  
  try {
    const project = JSON.parse(localStorage.getItem(keys[idx]));
    newProject();
    project.layers.forEach(l => addLayer(l.name, l.geojson, l.style));
    toast('Проект загружен', 'success');
  } catch (err) {
    toast('Ошибка загрузки: ' + err.message, 'error');
  }
}

function newProject() {
  if (!confirm('Создать новый проект? Текущие слои будут удалены.')) return;
  Object.values(state.layers).forEach(l => map.removeLayer(l.layer));
  state.layers = {};
  state.layerCounter = 0;
  refreshLayerList();
  refreshSelects();
  toast('Новый проект создан', 'success');
}

// ============ ANALYSIS TOOLS ============
function getLayerGeoJSON(id) {
  return state.layers[id]?.layer.toGeoJSON();
}

function createBuffer() {
  const layerId = document.getElementById('buf-layer').value;
  const radius = parseFloat(document.getElementById('buf-radius').value);
  if (!layerId || !radius) return toast('Заполните все поля', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  const buffered = turf.buffer(geojson, radius, {units: 'kilometers'});
  addLayer(`${state.layers[layerId].name}_буфер_${radius}км`, buffered, {
    color: '#ff5555',
    fillColor: '#ff5555',
    fillOpacity: 0.3
  });
}

function createCentroid() {
  const layerId = document.getElementById('cent-layer').value;
  if (!layerId) return toast('Выберите слой', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  const centroids = turf.centroid(geojson);
  addLayer(`${state.layers[layerId].name}_центроиды`, centroids, {
    color: '#50fa7b',
    fillColor: '#50fa7b',
    radius: 8
  });
}

function createConvexHull() {
  const layerId = document.getElementById('conv-layer').value;
  if (!layerId) return toast('Выберите слой', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  try {
    const hull = turf.convex(geojson);
    if (!hull) return toast('Невозможно построить оболочку', 'error');
    addLayer(`${state.layers[layerId].name}_оболочка`, hull, {
      color: '#f1fa8c',
      fillColor: '#f1fa8c',
      fillOpacity: 0.2,
      weight: 3
    });
  } catch (err) {
    toast('Ошибка: ' + err.message, 'error');
  }
}

function calcMeasure() {
  const layerId = document.getElementById('measure-layer').value;
  if (!layerId) return toast('Выберите слой', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  let result = '';
  
  geojson.features.forEach((f, i) => {
    if (f.geometry.type === 'Polygon' || f.geometry.type === 'MultiPolygon') {
      const area = turf.area(f) / 1e6; // km²
      result += `Объект ${i+1}: ${area.toFixed(2)} км²\n`;
    } else if (f.geometry.type === 'LineString' || f.geometry.type === 'MultiLineString') {
      const length = turf.length(f, {units: 'kilometers'});
      result += `Объект ${i+1}: ${length.toFixed(2)} км\n`;
    }
  });
  
  document.getElementById('measure-out').textContent = result || 'Нет полигонов/линий';
}

function calcIntersect() {
  const aId = document.getElementById('int-a').value;
  const bId = document.getElementById('int-b').value;
  if (!aId || !bId) return toast('Выберите оба слоя', 'error');
  
  const a = getLayerGeoJSON(aId);
  const b = getLayerGeoJSON(bId);
  
  try {
    const features = [];
    a.features.forEach(fa => {
      b.features.forEach(fb => {
        try {
          const inter = turf.intersect(fa, fb);
          if (inter) features.push(inter);
        } catch(e) {}
      });
    });
    
    if (features.length === 0) return toast('Пересечений не найдено', 'info');
    
    const result = {type: 'FeatureCollection', features};
    addLayer(`пересечение_${state.layers[aId].name}_${state.layers[bId].name}`, result, {
      color: '#ff79c6',
      fillColor: '#ff79c6',
      fillOpacity: 0.5
    });
  } catch (err) {
    toast('Ошибка: ' + err.message, 'error');
  }
}

function calcUnion() {
  const aId = document.getElementById('uni-a').value;
  const bId = document.getElementById('uni-b').value;
  if (!aId || !bId) return toast('Выберите оба слоя', 'error');
  
  const a = getLayerGeoJSON(aId);
  const b = getLayerGeoJSON(bId);
  
  try {
    let result = a.features[0];
    a.features.slice(1).forEach(f => {
      result = turf.union(result, f);
    });
    b.features.forEach(f => {
      result = turf.union(result, f);
    });
    
    addLayer(`объединение_${state.layers[aId].name}_${state.layers[bId].name}`, 
      {type: 'FeatureCollection', features: [result]}, {
      color: '#bd93f9',
      fillColor: '#bd93f9',
      fillOpacity: 0.4
    });
  } catch (err) {
    toast('Ошибка: ' + err.message, 'error');
  }
}

function loadFilterFields() {
  const layerId = document.getElementById('filt-layer').value;
  if (!layerId) return;
  
  const geojson = getLayerGeoJSON(layerId);
  const fields = new Set();
  geojson.features.forEach(f => {
    if (f.properties) Object.keys(f.properties).forEach(k => fields.add(k));
  });
  
  const sel = document.getElementById('filt-field');
  sel.innerHTML = Array.from(fields).map(f => `<option value="${f}">${f}</option>`).join('');
}

function applyFilter() {
  const layerId = document.getElementById('filt-layer').value;
  const field = document.getElementById('filt-field').value;
  const value = document.getElementById('filt-value').value;
  
  if (!layerId || !field) return toast('Заполните все поля', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  const filtered = {
    type: 'FeatureCollection',
    features: geojson.features.filter(f => 
      f.properties && String(f.properties[field]) === value
    )
  };
  
  addLayer(`${state.layers[layerId].name}_фильтр_${field}=${value}`, filtered);
}

function clearFilter() {
  document.getElementById('filt-field').innerHTML = '';
  document.getElementById('filt-value').value = '';
}

function createGrid() {
  const layerId = document.getElementById('grid-layer').value;
  const step = parseFloat(document.getElementById('grid-step').value);
  if (!layerId || !step) return toast('Заполните все поля', 'error');
  
  const geojson = getLayerGeoJSON(layerId);
  const bbox = turf.bbox(geojson);
  
  try {
    const grid = turf.pointGrid(bbox, step, {units: 'kilometers'});
    // Фильтруем точки внутри полигонов
    const filtered = {
      type: 'FeatureCollection',
      features: grid.features.filter(p => 
        turf.booleanPointInPolygon(p, geojson.features[0])
      )
    };
    
    addLayer(`сетка_${step}км`, filtered, {
      color: '#ffb86c',
      fillColor: '#ffb86c',
      radius: 4
    });
  } catch (err) {
    toast('Ошибка: ' + err.message, 'error');
  }
}

