    headers.forEach(h => html += `<td>${f.properties?.[h] ?? ''}</td>`);
    html += '</tr>';
  });
  html += '</table>';
  
  showModal(`📋 Атрибуты: ${state.layers[layerId].name}`, html);
}

function addAttribute() {
  const layerId = document.getElementById('attr-layer').value;
  if (!layerId) return toast('Выберите слой', 'error');
  
  const name = prompt('Имя нового поля:');
  if (!name) return;
  const value = prompt('Значение по умолчанию:', '');
  
  const geojson = getLayerGeoJSON(layerId);
  geojson.features.forEach(f => {
    if (!f.properties) f.properties = {};
    f.properties[name] = value;
  });
  
  state.layers[layerId].layer.clearLayers();
  state.layers[layerId].layer.addData(geojson);
  toast(`Поле "${name}" добавлено`, 'success');
}

function showAttributes() {
  const layerId = document.getElementById('attr-layer').value;
  if (!layerId) return;
  const geojson = getLayerGeoJSON(layerId);
  const count = geojson.features.length;
  const fields = new Set();
  geojson.features.forEach(f => {
    if (f.properties) Object.keys(f.properties).forEach(k => fields.add(k));
  });
  toast(`Объектов: ${count}, полей: ${fields.size}`, 'info');
