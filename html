<!-- Leaflet Measure -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/ljagis/leaflet-measure@3.0.0/dist/leaflet-measure.css"/>
<script src="https://cdn.jsdelivr.net/gh/ljagis/leaflet-measure@3.0.0/dist/leaflet-measure.min.js"></script>

<style>
:root{
  --bg:#1e1e2e; --panel:#282a36; --panel2:#2f3242; --accent:#8be9fd;
  --accent2:#50fa7b; --text:#f8f8f2; --muted:#6272a4; --danger:#ff5555;
  --border:#44475a; --yellow:#f1fa8c;
}
*{box-sizing:border-box}
html,body{margin:0;height:100%;font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);overflow:hidden}
#app{display:flex;flex-direction:column;height:100vh}

/* TOP BAR */
header{background:linear-gradient(90deg,#14141e,#1e1e2e);padding:8px 14px;display:flex;align-items:center;gap:14px;border-bottom:1px solid var(--border);z-index:1000}
header .logo{font-weight:700;font-size:18px;color:var(--accent);letter-spacing:1px}
header .logo span{color:var(--accent2)}
header .user{margin-left:auto;display:flex;gap:8px;align-items:center}
header button{background:var(--panel2);color:var(--text);border:1px solid var(--border);padding:5px 12px;border-radius:4px;cursor:pointer;font-size:12px;transition:.2s}
header button:hover{background:var(--accent);color:#000;border-color:var(--accent)}

/* MAIN */
main{flex:1;display:flex;overflow:hidden}
aside{width:280px;background:var(--panel);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.tabs{display:flex;border-bottom:1px solid var(--border)}
.tabs button{flex:1;background:none;border:none;color:var(--muted);padding:10px 5px;cursor:pointer;font-size:11px;border-bottom:2px solid transparent}
.tabs button.active{color:var(--accent);border-color:var(--accent);background:var(--panel2)}
.tab-content{flex:1;overflow-y:auto;padding:10px}
.tab-content:not(.active){display:none}

section.panel{background:var(--panel2);border:1px solid var(--border);border-radius:6px;margin-bottom:10px;padding:10px}
section.panel h3{margin:0 0 8px;font-size:12px;color:var(--accent);text-transform:uppercase;letter-spacing:1px}
section.panel label{font-size:11px;color:var(--muted);display:block;margin:6px 0 3px}
section.panel input,section.panel select,section.panel textarea{
  width:100%;background:#1e1e2e;color:var(--text);border:1px solid var(--border);border-radius:4px;padding:6px;font-size:12px;font-family:inherit
}
section.panel textarea{min-height:80px;font-family:'Consolas',monospace}
section.panel button, .btn{
  width:100%;background:var(--accent);color:#000;border:none;padding:7px;border-radius:4px;cursor:pointer;font-weight:600;font-size:12px;margin-top:6px
}
section.panel button.secondary,.btn.secondary{background:var(--panel);color:var(--text);border:1px solid var(--border)}
section.panel button.danger,.btn.danger{background:var(--danger);color:#fff}
section.panel button:hover{filter:brightness(1.15)}

.layer-item{display:flex;align-items:center;gap:6px;padding:6px;background:#1e1e2e;border:1px solid var(--border);border-radius:4px;margin-bottom:5px;font-size:11px;cursor:pointer}
.layer-item:hover{border-color:var(--accent)}
.layer-item.active{border-color:var(--accent2);background:#243a2f}
.layer-item input[type=checkbox]{accent-color:var(--accent2)}
.layer-item .lname{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.layer-item .actions{display:flex;gap:3px}
.layer-item .actions button{width:22px;height:22px;padding:0;background:var(--panel);border:1px solid var(--border);border-radius:3px;color:var(--text);cursor:pointer;font-size:11px}

#map{flex:1;background:#111}
.leaflet-container{background:#111}

/* STATUS BAR */
footer{background:var(--panel);border-top:1px solid var(--border);padding:4px 14px;font-size:11px;color:var(--muted);display:flex;gap:20px}
footer span b{color:var(--accent)}

/* MODAL */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:9999}
.modal{background:var(--panel);border:1px solid var(--border);border-radius:8px;padding:24px;min-width:340px;max-width:600px;max-height:80vh;overflow-y:auto}
.modal h2{margin:0 0 15px;color:var(--accent)}
.modal table{width:100%;border-collapse:collapse;font-size:12px}
.modal th,.modal td{border:1px solid var(--border);padding:5px 8px;text-align:left}
.modal th{background:var(--panel2);color:var(--accent)}

/* TOAST */
#toast{position:fixed;bottom:40px;right:20px;z-index:10000;display:flex;flex-direction:column;gap:8px}
.toast{background:var(--panel2);border-left:4px solid var(--accent);padding:10px 16px;border-radius:4px;box-shadow:0 4px 12px rgba(0,0,0,.5);font-size:12px;animation:slide .3s}
.toast.error{border-color:var(--danger)}
.toast.success{border-color:var(--accent2)}
@keyframes slide{from{transform:translateX(100%);opacity:0}}

/* Scrollbar */
::-webkit-scrollbar{width:8px;height:8px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:var(--accent)}
</style>
</head>
